<% layout("/layouts/boilerplate.ejs") %>

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<section class="profile-section">
  <div class="ambient-glow-1"></div>
  <div class="ambient-glow-2"></div>
  <div class="grid-overlay"></div>

  <div class="container relative-z">
    
    <div class="profile-hero fade-in-up">
      <div class="profile-info">
        <div class="avatar-wrapper">
          <div class="avatar-placeholder">
            <%= user.username.charAt(0).toUpperCase() %>
          </div>
          <div class="online-indicator"></div>
        </div>
        <div class="text-content">
          <div class="badge-glass mb-2">Member Dashboard</div>
          <h1 class="gradient-title">Welcome, <%= user.username %></h1>
          <p class="text-muted-custom">Manage your curated collection of specialized AI assets.</p>
        </div>
      </div>

      <div class="profile-stats">
        <div class="stat-item">
          <span class="stat-value"><%= user.savedListings.length %></span>
          <span class="stat-label">Saved Tools</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-value"><%= new Date().toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %></span>
          <span class="stat-label">Member Since</span>
        </div>
        <div class="share-action">
          <button class="btn-share-stack" onclick="copyStackLink()">
            <i class="fa-solid fa-arrow-up-right-from-square"></i>
            <span>Share Stack</span>
          </button>
        </div>
      </div>
    </div>

    <div class="section-title-row fade-in-up" style="animation-delay: 0.1s;">
      <h2 class="section-heading">Your Curated Stack</h2>
      <div class="heading-line"></div>
    </div>

    <div class="row g-4" id="toolsGrid">
      <% if(user.savedListings && user.savedListings.length > 0) { %>
        <% for(let listing of user.savedListings) { %>
          <div class="col-xl-4 col-lg-4 col-md-6 tool-card-col">
            <div class="spotlight-card h-100 fade-in-up-stagger">
              <div class="card-inner">
                
                <div class="card-top-row">
                  <div class="tool-icon-wrapper">
                    <img src="<%= listing.logo && listing.logo.url ? listing.logo.url : 'https://placehold.co/200x200/1e1b4b/a855f7?text=AI' %>" alt="logo">
                  </div>
                  <div class="d-flex align-items-start gap-2">
                    <span class="pricing-pill <%= listing.pricingModel === 'Free' ? 'free-tier' : 'paid-tier' %>">
                      <%= listing.pricingModel %>
                    </span>
                    <button class="btn-unsave" data-id="<%= listing._id %>" title="Remove from Stack">
                      <i class="fa-solid fa-heart"></i>
                    </button>
                  </div>
                </div>

                <div class="card-content flex-grow-1">
                  <div class="card-meta">
                    <span class="category-tag"><%= listing.category %></span>
                  </div>
                  <h3 class="tool-title"><%= listing.name %></h3>
                  <p class="tool-desc">
                    <%= listing.description.length > 90 ? listing.description.substring(0, 90) + '...' : listing.description %>
                  </p>
                </div>

                <div class="card-actions">
                  <a href="/home/listings/<%= listing._id %>" class="btn-details">
                    View Details
                  </a>
                  <a href="<%= listing.websiteUrl %>" target="_blank" class="btn-visit">
                    <i class="fa-solid fa-external-link"></i>
                  </a>
                </div>

              </div>
            </div>
          </div>
        <% } %>
      <% } else { %>
        <div class="col-12">
          <div class="empty-state-glass py-5 fade-in-up">
            <div class="empty-icon-wrapper">
              <i class="fa-regular fa-folder-open"></i>
            </div>
            <h4>Your stack is currently empty</h4>
            <p>Discover and save tools from our directory to build your personalized AI workflow.</p>
            <a href="/home/listings" class="btn-explore-now">Explore Directory</a>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<style>
  /* --- Professional Theme Overrides --- */
  :root {
    --glass: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.08);
    --accent-purple: #a855f7;
    --accent-cyan: #06b6d4;
  }

  .profile-section {
    position: relative;
    min-height: 100vh;
    background-color: #030305;
    padding: 140px 0 100px;
    overflow: hidden;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.02) 1px, transparent 0);
    background-size: 40px 40px;
    z-index: 0;
  }

  /* --- Hero Card --- */
  .profile-hero {
    background: rgba(15, 15, 20, 0.6);
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: 32px;
    padding: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 60px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.4);
  }

  .profile-info { display: flex; align-items: center; gap: 30px; }

  .avatar-wrapper { position: relative; }
  .avatar-placeholder {
    width: 100px; height: 100px;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-cyan));
    border-radius: 24px;
    display: flex; align-items: center; justify-content: center;
    font-size: 2.5rem; font-weight: 800; color: white;
    box-shadow: 0 10px 25px rgba(168, 85, 247, 0.3);
  }
  .online-indicator {
    position: absolute; bottom: -5px; right: -5px;
    width: 20px; height: 20px; background: #10b981;
    border: 4px solid #0f0f14; border-radius: 50%;
  }

  .profile-stats { display: flex; align-items: center; gap: 40px; }
  .stat-item { text-align: center; }
  .stat-value { display: block; font-size: 1.8rem; font-weight: 800; color: #fff; }
  .stat-label { font-size: 0.8rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; }
  .stat-divider { width: 1px; height: 40px; background: var(--glass-border); }

  .btn-share-stack {
    background: #fff; color: #000; border: none;
    padding: 12px 24px; border-radius: 14px;
    font-weight: 700; display: flex; align-items: center; gap: 10px;
    transition: 0.3s;
  }
  .btn-share-stack:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(255,255,255,0.2); }

  /* --- Grid Section --- */
  .section-title-row { display: flex; align-items: center; gap: 20px; margin-bottom: 30px; }
  .section-heading { font-size: 1.5rem; font-weight: 700; white-space: nowrap; color: #fff; }
  .heading-line { height: 1px; background: var(--glass-border); width: 100%; }

  /* --- Card Customizations --- */
  .btn-unsave {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    color: #ef4444; width: 38px; height: 38px;
    border-radius: 50%; cursor: pointer; transition: 0.3s;
  }
  .btn-unsave:hover { background: #ef4444; color: #fff; transform: scale(1.1); }

  .category-tag {
    font-size: 0.7rem; color: var(--accent-cyan);
    font-weight: 700; text-transform: uppercase;
    background: rgba(6, 182, 212, 0.1);
    padding: 4px 10px; border-radius: 6px;
  }

  .btn-details {
    flex-grow: 1; padding: 12px; border-radius: 12px;
    background: var(--glass); border: 1px solid var(--glass-border);
    color: #fff; text-align: center; text-decoration: none; font-weight: 600;
    transition: 0.3s;
  }
  .btn-details:hover { background: rgba(255,255,255,0.08); border-color: #fff; }

  .btn-visit {
    padding: 12px 18px; border-radius: 12px;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-cyan));
    color: #fff; border: none; transition: 0.3s;
  }
  .btn-visit:hover { transform: scale(1.05); filter: brightness(1.1); }

  /* --- Empty State Glass --- */
  .empty-state-glass {
    background: var(--glass); border: 1px solid var(--glass-border);
    border-radius: 24px; text-align: center; padding: 60px;
  }
  .empty-icon-wrapper {
    width: 80px; height: 80px; background: rgba(255,255,255,0.03);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px; font-size: 2.5rem; color: #4b5563;
  }

  @media (max-width: 992px) {
    .profile-hero { flex-direction: column; gap: 30px; text-align: center; }
    .profile-info { flex-direction: column; }
  }
  /* ==========================================================================
     UNIFORM AI TOOL ICONS
     ========================================================================== */
     .tool-icon-wrapper {
    /* Step 1: Create a perfect, standardized, square box for every icon */
    width: 60px;
    height: 60px;
    
    /* Step 2: Styling and placement (Matching your theme) */
    border-radius: 14px;
    overflow: hidden;
    background: #050505;
    border: 1px solid rgba(255, 255, 255, 0.1);
    
    /* Step 3: Crucial - Ensures this box doesn't shrink on mobile */
    flex-shrink: 0;
    
    /* Step 4: Add subtle padding to prevent wide logos from touching the edges */
    padding: 6px;
    
    /* Step 5: Centers the image horizontally and vertically within the padding */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tool-icon-wrapper img {
    /* Step 1: Make the image fill the max available width of the 60px box */
    width: 100%;
    
    /* Step 2: Ensure tall images don't stretch the box height */
    max-height: 100%;
    
    /* Step 3: THE MOST CRUCIAL PROPERTY:
       This prevents stretching. The image will fit *inside* the padding,
       keeping its natural aspect ratio. Any empty space is filled by the 
       background color of the box. */
    object-fit: contain;
    
    border-radius: 8px; /* Subtle internal rounding for the logo itself */
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // Re-applying spotlight effect
    const cards = document.querySelectorAll('.spotlight-card');
    cards.forEach(card => {
        card.addEventListener('mousemove', e => {
            const rect = card.getBoundingClientRect();
            card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
            card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
        });
    });

    // Unsave Logic with smooth animation
    const unsaveBtns = document.querySelectorAll('.btn-unsave');
    unsaveBtns.forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const listingId = btn.getAttribute('data-id');
            const cardCol = btn.closest('.tool-card-col');
            
            btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i>';
            
            try {
                const response = await fetch(`/home/listings/${listingId}/toggle-save`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                
                if (data.success && !data.isSaved) {
                    cardCol.style.transition = 'all 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
                    cardCol.style.opacity = '0';
                    cardCol.style.transform = 'translateY(20px) scale(0.9)';
                    setTimeout(() => {
                        cardCol.remove();
                        // Optional: Refresh page if last item removed to show empty state
                        if(document.querySelectorAll('.tool-card-col').length === 0) location.reload();
                    }, 500);
                }
            } catch (err) {
                console.error("Failed to unsave:", err);
            }
        });
    });
});

function copyStackLink() {
    const url = window.location.href;
    navigator.clipboard.writeText(url).then(() => {
        const btn = document.querySelector('.btn-share-stack span');
        const originalText = btn.innerText;
        btn.innerText = "Link Copied!";
        setTimeout(() => btn.innerText = originalText, 2000);
    });
}
</script>