<nav id="ainexusNav" class="navbar navbar-expand-lg navbar-dark floating-pill-nav">
  <div class="container-fluid px-3">
    
    <a class="navbar-brand d-flex align-items-center gap-2" href="/home">
      <div class="logo-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 20L12 4L21 20" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          
          <path d="M12 4C14 6 16 8 16 10" stroke="#4cc9f0" stroke-width="2" stroke-linecap="round"/>
          <path d="M12 4C10 6 8 8 8 10" stroke="#4cc9f0" stroke-width="2" stroke-linecap="round"/>
          
          <circle cx="12" cy="12" r="1" fill="white"/>
        </svg>
      </div>
      <span class="brand-text">AiNexus</span>
    </a>

    <button class="navbar-toggler custom-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <i class="fa-solid fa-bars-staggered"></i>
    </button>

    <div class="collapse navbar-collapse justify-content-between" id="navbarNav">
      
      <ul class="navbar-nav mx-auto align-items-center gap-1">
        <li class="nav-item">
          <a class="nav-link active" href="/home">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/home/listings">Explore AI</a>
        </li>
        <% if(currUser && currUser.username === 'admin') { %>
          <li class="nav-item">
            <a class="nav-link" href="/home/listings/new">Submit Tool</a>
          </li>
        <% } %>
        <li class="nav-item">
          <a class="nav-link" href="/home/listings/compare">Compare</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/home/guide">Community</a>
        </li>
      </ul>
      
      <div class="d-flex flex-column flex-lg-row align-items-center gap-3 auth-container mt-3 mt-lg-0">
        <% if(!currUser) { %>
          <a href="/login" class="nav-link-btn login-link">Log In</a>
          <a href="/signup" class="btn-glow">
            <span>Sign Up</span>
            <div class="glow-effect"></div>
          </a>
        <% } else { %>
          <div class="user-profile-btn">
            <span class="text-white me-3">Welcome Back</span>
            <a href="/logout" class="btn-outline-danger">Log Out</a>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</nav>

<style>
  /* Wrapper to prevent layout jumps */
  body {
    padding-top: 10px; 
    background-color: #050505 !important; /* Forces the background to be deep dark */
    color: #e4e4e7; /* Sets default text color to a soft white */
    min-height: 100vh;
    margin: 0;
  }

  /* The Floating Pill Base */
  .floating-pill-nav {
    position: fixed;
    top: 25px;
    left: 50%;
    transform: translateX(-50%);
    width: 92%;
    max-width: 1200px;
    background: rgba(15, 15, 15, 0.65);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 100px;
    padding: 8px 12px;
    z-index: 1050;
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.5);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Scroll Animation State */
  .floating-pill-nav.scrolled {
    width: 85%; /* Shrinks slightly on scroll */
    top: 15px;
    background: rgba(5, 5, 5, 0.85);
    border-color: rgba(99, 102, 241, 0.3); /* Subtle indigo border glow */
    box-shadow: 0 15px 35px -5px rgba(99, 102, 241, 0.15);
  }

  /* Logo Styling */
  .logo-icon-wrapper {
    background: linear-gradient(135deg, #6366f1, #a855f7);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 15px rgba(99, 102, 241, 0.5);
  }

  .accent-icon {
    color: #ffffff;
    font-size: 1rem;
  }

  .brand-text {
    font-weight: 700;
    font-size: 1.25rem;
    color: #ffffff;
    letter-spacing: -0.5px;
  }

  /* Pill Links with Animated Hover Backgrounds */
  .floating-pill-nav .nav-link {
    color: #a1a1aa !important;
    font-weight: 500;
    font-size: 0.95rem;
    padding: 10px 20px !important;
    border-radius: 50px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .floating-pill-nav .nav-link:hover,
  .floating-pill-nav .nav-link.active {
    color: #ffffff !important;
    background: rgba(255, 255, 255, 0.06);
  }

  /* Login Text Link */
  .login-link {
    color: #a1a1aa;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: color 0.3s ease;
  }

  .login-link:hover {
    color: #ffffff;
  }

  /* Modern Animated Signup Button */
  .btn-glow {
    position: relative;
    background: #ffffff;
    color: #050505;
    padding: 10px 24px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .btn-glow span {
    position: relative;
    z-index: 2;
  }

  .btn-glow:hover {
    transform: scale(1.05);
    color: #050505;
  }

  /* Rotating Gradient Glow inside button */
  .glow-effect {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: conic-gradient(from 0deg, transparent, rgba(99, 102, 241, 0.3), transparent);
    animation: rotate 4s linear infinite;
    z-index: 1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .btn-glow:hover .glow-effect {
    opacity: 1;
  }

  @keyframes rotate {
    100% { transform: rotate(360deg); }
  }

  /* Logout Button */
  .btn-outline-danger {
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
    padding: 8px 20px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .btn-outline-danger:hover {
    background: rgba(239, 68, 68, 0.1);
    border-color: #ef4444;
    color: #ef4444;
  }

  /* Mobile Adjustments */
  .custom-toggler {
    border: none;
    color: #ffffff;
  }
  
  .custom-toggler:focus {
    box-shadow: none;
  }

  @media (max-width: 991px) {
    .floating-pill-nav {
      border-radius: 20px; /* Less rounded when expanded on mobile */
      padding: 15px;
      width: 95%;
    }
    .floating-pill-nav .nav-link {
      text-align: center;
      margin: 5px 0;
    }
    .auth-container {
      padding-top: 15px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      width: 100%;
      justify-content: center;
    }
    .btn-glow {
      width: 100%;
      text-align: center;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const navbar = document.getElementById("ainexusNav");
    
    window.addEventListener("scroll", function() {
      if (window.scrollY > 50) {
        navbar.classList.add("scrolled");
      } else {
        navbar.classList.remove("scrolled");
      }
    });
  });
</script>