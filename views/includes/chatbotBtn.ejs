<a href="/home/chatbot" id="floatingChatBtn" class="floating-chat-btn">
  <div class="chat-icon-wrapper">
      <i class="fa-solid fa-brain"></i>
  </div>
  <span class="chat-tooltip">Ask AI</span>
</a>

<script>
  document.addEventListener("DOMContentLoaded", () => {
      const chatBtn = document.getElementById('floatingChatBtn');

      if (chatBtn) {
          // Check the current page URL
          // If the URL contains '/chatbot', hide the button!
          if (window.location.pathname.includes('/chatbot')) {
              chatBtn.style.display = 'none';
          } else {
              // Otherwise, make sure it is visible
              chatBtn.style.display = 'flex';
          }
      }
  });
</script>

<style>
  /* Premium floating button styling */
  .floating-chat-btn {
      position: fixed;
      bottom: 30px;
      right: 30px;
      z-index: 9999;
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      animation: floatUpAndDown 4s ease-in-out infinite;
      transition: transform 0.3s ease;
  }

  .floating-chat-btn:hover {
      transform: scale(1.1) translateY(-5px);
  }

  .chat-icon-wrapper {
      width: 56px;
      height: 56px;
      background: linear-gradient(135deg, #6366f1, #a855f7);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      color: #fff;
      box-shadow: 0 10px 25px rgba(168, 85, 247, 0.4);
      border: 2px solid rgba(255, 255, 255, 0.2);
  }

  .chat-tooltip {
      background: rgba(15, 15, 20, 0.9);
      color: #fff;
      padding: 6px 12px;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 600;
      border: 1px solid rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      opacity: 0;
      transform: translateX(10px);
      transition: all 0.3s ease;
      pointer-events: none;
  }

  .floating-chat-btn:hover .chat-tooltip {
      opacity: 1;
      transform: translateX(0);
  }

  @keyframes floatUpAndDown {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
      .floating-chat-btn { bottom: 20px; right: 20px; }
      .chat-icon-wrapper { width: 50px; height: 50px; font-size: 1.3rem; }
      .chat-tooltip { display: none; }
  }
</style>