<% layout("/layouts/boilerplate.ejs") %>

<section class="add-tool-section">
  <div class="ambient-glow-add-1"></div>
  <div class="ambient-glow-add-2"></div>

  <div class="form-glass-container fade-in-up">
    <div class="form-header">
      <div class="logo-icon-wrapper-large">
        <i class="fa-solid fa-cube"></i>
      </div>
      <h2>Add New AI Tool</h2>
      <p>Submit a new AI platform to the AiNexus directory.</p>
    </div>

    <form action="/home/listings" method="POST" class="needs-validation ainexus-auth-form" novalidate>
      
      <div class="form-grid">
        <div class="form-group">
          <label for="name">Tool Name <span class="required">*</span></label>
          <div class="input-wrapper">
            <i class="fa-solid fa-robot input-icon"></i>
            <input type="text" id="name" name="listing[name]" placeholder="e.g., ChatGPT" required>
            <div class="invalid-feedback">Please enter a tool name.</div>
          </div>
        </div>

        <div class="form-group">
          <label for="category">Category <span class="required">*</span></label>
          <div class="input-wrapper">
            <i class="fa-solid fa-layer-group input-icon"></i>
            <select id="category" name="listing[category]" required>
              <option value="" disabled selected>Select Category</option>
              <option value="Text Generation">Text Generation</option>
              <option value="Image Generation">Image Generation</option>
              <option value="Video Editing">Video Editing</option>
              <option value="Code Assistant">Code Assistant</option>
              <option value="Productivity">Productivity</option>
              <option value="Chatbot">Chatbot</option>
              <option value="Voice AI">Voice AI</option>
              <option value="Other">Other</option>
            </select>
            <div class="invalid-feedback">Please select a category.</div>
          </div>
        </div>

        <div class="form-group">
          <label for="websiteUrl">Official Website URL <span class="required">*</span></label>
          <div class="input-wrapper">
            <i class="fa-solid fa-link input-icon"></i>
            <input type="url" id="websiteUrl" name="listing[websiteUrl]" placeholder="https://..." required>
            <div class="invalid-feedback">Please provide a valid URL.</div>
          </div>
        </div>

        <div class="form-group">
          <label for="logo">Logo URL <span class="text-muted-custom">(Optional)</span></label>
          <div class="input-wrapper">
            <i class="fa-solid fa-image input-icon"></i>
            <input type="text" id="logo" name="listing[logo]" placeholder="Paste image URL here">
          </div>
        </div>

        <div class="form-group full-width">
          <label for="description">Description <span class="required">*</span></label>
          <textarea id="description" name="listing[description]" rows="4" placeholder="Briefly describe what this AI tool does..." required></textarea>
          <div class="invalid-feedback">Please provide a description.</div>
        </div>
      </div>

      <div class="action-row mt-4">
        <button type="submit" class="btn-submit-glow">
          <span>Add AI Tool</span>
          <i class="fa-solid fa-plus ms-2"></i>
        </button>
      </div>

    </form>
  </div>
</section>

<style>
  /* Section Setup */
  .add-tool-section {
    position: relative;
    min-height: 100vh;
    background-color: #050505;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 100px 20px 60px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    overflow: hidden;
  }

  /* Ambient Glows */
  .ambient-glow-add-1 {
    position: absolute;
    top: 10%;
    left: 20%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
    filter: blur(50px);
    z-index: 0;
    pointer-events: none;
  }

  .ambient-glow-add-2 {
    position: absolute;
    bottom: 10%;
    right: 20%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.1) 0%, transparent 70%);
    filter: blur(60px);
    z-index: 0;
    pointer-events: none;
  }

  /* Main Glass Container */
  .form-glass-container {
    position: relative;
    z-index: 2;
    background: rgba(15, 15, 15, 0.7);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.7), inset 0 0 0 1px rgba(168, 85, 247, 0.1);
    width: 100%;
    max-width: 800px;
    padding: 50px;
  }

  /* Header */
  .form-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .logo-icon-wrapper-large {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(168, 85, 247, 0.2));
    border: 1px solid rgba(168, 85, 247, 0.4);
    border-radius: 16px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0 auto 20px;
    font-size: 1.6rem;
    color: #c084fc;
    box-shadow: 0 10px 25px rgba(168, 85, 247, 0.2);
  }

  .form-header h2 {
    color: #ffffff;
    font-weight: 700;
    font-size: 2.2rem;
    letter-spacing: -0.5px;
    margin-bottom: 8px;
  }

  .form-header p {
    color: #a1a1aa;
    font-size: 1rem;
  }

  /* Grid Layout */
  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .full-width {
    grid-column: 1 / -1;
  }

  /* Inputs & Labels */
  .form-group label {
    display: block;
    color: #e4e4e7;
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .required { color: #ef4444; }
  .text-muted-custom { color: #71717a; font-weight: 400; font-size: 0.8rem; }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-icon {
    position: absolute;
    left: 16px;
    color: #71717a;
    font-size: 1rem;
    pointer-events: none;
    transition: color 0.3s ease;
  }

  .input-wrapper input,
  .input-wrapper select,
  textarea {
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: #ffffff;
    font-family: inherit;
    font-size: 0.95rem;
    transition: all 0.3s ease;
  }

  .input-wrapper input,
  .input-wrapper select {
    padding: 14px 16px 14px 45px; /* Space for icon */
  }

  textarea {
    padding: 14px 16px;
    resize: vertical;
    min-height: 120px;
  }

  .input-wrapper select {
    appearance: none;
    cursor: pointer;
    color: #a1a1aa; /* Default color before selection */
  }
  
  .input-wrapper select:valid {
    color: #ffffff; /* Turns white once an option is selected */
  }

  .input-wrapper input::placeholder,
  textarea::placeholder {
    color: #52525b;
  }

  .input-wrapper input:focus,
  .input-wrapper select:focus,
  textarea:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.06);
    border-color: #a855f7;
    box-shadow: 0 0 0 4px rgba(168, 85, 247, 0.15);
  }

  .input-wrapper input:focus + .input-icon,
  .input-wrapper select:focus + .input-icon {
    color: #a855f7;
  }

  /* Validation */
  .invalid-feedback {
    display: none;
    color: #ef4444;
    font-size: 0.85rem;
    margin-top: 5px;
  }

  .was-validated input:invalid,
  .was-validated select:invalid,
  .was-validated textarea:invalid {
    border-color: #ef4444;
  }

  .was-validated input:invalid ~ .invalid-feedback,
  .was-validated select:invalid ~ .invalid-feedback,
  .was-validated textarea:invalid + .invalid-feedback {
    display: block;
  }

  /* Submit Button */
  .btn-submit-glow {
    width: 100%;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    color: white;
    border: none;
    padding: 16px;
    font-size: 1.1rem;
    font-weight: 700;
    border-radius: 12px;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 0.3s ease;
    box-shadow: 0 8px 20px rgba(99, 102, 241, 0.3);
  }

  .btn-submit-glow:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 25px rgba(99, 102, 241, 0.5);
  }

  /* Animation */
  .fade-in-up {
    animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeInUp {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* Mobile Adjustments */
  @media (max-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr; /* Stack inputs on mobile */
    }
    .form-glass-container {
      padding: 30px 20px;
    }
    .form-header h2 {
      font-size: 1.8rem;
    }
  }
</style>

<script>
  (function () {
    'use strict'
    var forms = document.querySelectorAll('.needs-validation')
    Array.prototype.slice.call(forms).forEach(function (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault()
          event.stopPropagation()
        }
        form.classList.add('was-validated')
      }, false)
    })
  })()
</script>