<% layout("/layouts/boilerplate.ejs") %>

<section class="community-section">
  <div class="ambient-glow-comm-1"></div>
  <div class="ambient-glow-comm-2"></div>

  <div class="container relative-z">
    
    <div class="community-header fade-in-up">
      <div class="logo-icon-wrapper-large mx-auto mb-3">
        <i class="fa-solid fa-users-rays text-white fs-3"></i>
      </div>
      <h1 class="gradient-title">The AiNexus Community</h1>
      <p class="text-muted-custom mx-auto" style="max-width: 600px;">
        Join thousands of AI enthusiasts, developers, and creators discovering the future together. Share your insights, review tools, and level up your workflow.
      </p>
    </div>

    <div class="row g-4 justify-content-center mt-2 fade-in-up" style="animation-delay: 0.1s;">
      
      <div class="col-md-6 col-lg-3">
        <div class="glass-feature-card h-100">
          <div class="feature-icon-box">
            <i class="fa-solid fa-rocket"></i>
          </div>
          <h4 class="feature-title">Discover First</h4>
          <p class="feature-text">Get exclusive early access to the newest AI models and tools before they hit the mainstream.</p>
        </div>
      </div>
      
      <div class="col-md-6 col-lg-3">
        <div class="glass-feature-card h-100">
          <div class="feature-icon-box" style="background: linear-gradient(135deg, rgba(245, 158, 11, 0.2), rgba(217, 119, 6, 0.2)); color: #fbbf24; border-color: rgba(245, 158, 11, 0.4);">
            <i class="fa-solid fa-star"></i>
          </div>
          <h4 class="feature-title">Share Reviews</h4>
          <p class="feature-text">Help others make informed decisions by sharing your hands-on experience and ratings.</p>
        </div>
      </div>
      
      <div class="col-md-6 col-lg-3">
        <div class="glass-feature-card h-100">
          <div class="feature-icon-box" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.2), rgba(5, 150, 105, 0.2)); color: #34d399; border-color: rgba(16, 185, 129, 0.4);">
            <i class="fa-solid fa-code-branch"></i>
          </div>
          <h4 class="feature-title">Connect & Build</h4>
          <p class="feature-text">Network with founders and developers. Collaborate on prompts, workflows, and integrations.</p>
        </div>
      </div>
      
      <div class="col-md-6 col-lg-3">
        <div class="glass-feature-card h-100">
          <div class="feature-icon-box" style="background: linear-gradient(135deg, rgba(236, 72, 153, 0.2), rgba(219, 39, 119, 0.2)); color: #f472b6; border-color: rgba(236, 72, 153, 0.4);">
            <i class="fa-solid fa-medal"></i>
          </div>
          <h4 class="feature-title">Earn Badges</h4>
          <p class="feature-text">Gain reputation points and exclusive community badges by actively submitting and reviewing tools.</p>
        </div>
      </div>

    </div>

    <hr class="ainexus-divider my-5 fade-in-up" style="animation-delay: 0.2s;">

    <div class="row fade-in-up" style="animation-delay: 0.3s;">
      <div class="col-12 text-center mb-5">
        <h2 class="text-white fw-bold">Community Voices</h2>
        <p class="text-muted-custom">Hear from our top contributors and AI explorers.</p>
      </div>
      
      <div class="col-md-4 mb-4">
        <div class="testimonial-glass-card">
          <i class="fa-solid fa-quote-left quote-mark"></i>
          <p class="testimonial-text">"AiNexus completely changed how I find tools for my agency. The community reviews are brutally honest, which saves me hours of testing."</p>
          <div class="testimonial-author">
            <div class="author-avatar"><i class="fa-solid fa-user-astronaut"></i></div>
            <div>
              <h6 class="mb-0 text-white">Sarah Jenkins</h6>
              <small class="text-muted-custom">AI Automation Expert</small>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="testimonial-glass-card">
          <i class="fa-solid fa-quote-left quote-mark"></i>
          <p class="testimonial-text">"I submitted my small text-to-speech app here and the feedback from the community helped me fix three major bugs before the official launch!"</p>
          <div class="testimonial-author">
            <div class="author-avatar" style="background: #1e1b4b; color: #a855f7;"><i class="fa-solid fa-user-ninja"></i></div>
            <div>
              <h6 class="mb-0 text-white">David Chen</h6>
              <small class="text-muted-custom">Indie Developer</small>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="testimonial-glass-card">
          <i class="fa-solid fa-quote-left quote-mark"></i>
          <p class="testimonial-text">"The categorization and filtering makes finding niche coding assistants incredibly easy. Best AI directory on the web right now."</p>
          <div class="testimonial-author">
            <div class="author-avatar" style="background: #064e3b; color: #34d399;"><i class="fa-solid fa-user-tie"></i></div>
            <div>
              <h6 class="mb-0 text-white">Marcus Thorne</h6>
              <small class="text-muted-custom">Senior Software Eng.</small>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row mt-4 fade-in-up" style="animation-delay: 0.4s;">
      <div class="col-12">
        <div class="discord-cta-banner">
          <div class="cta-content">
            <h3><i class="fa-brands fa-discord me-2"></i> Join the Live Chat</h3>
            <p>Hop into the official AiNexus Discord server. Chat with developers, share AI prompts, and get real-time help from the community.</p>
            <a href="#" class="btn-discord-glow">Launch Discord</a>
          </div>
          <div class="cta-visual d-none d-lg-block">
            <i class="fa-brands fa-discord bg-icon"></i>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .community-section {
    position: relative;
    min-height: 100vh;
    background-color: #050505;
    padding: 120px 0 80px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #e4e4e7;
    overflow: hidden;
  }

  .relative-z { position: relative; z-index: 2; }
  .text-accent { color: #a855f7 !important; }
  .text-muted-custom { color: #a1a1aa; font-size: 1.05rem; line-height: 1.6;}

  /* Ambient Glows */
  .ambient-glow-comm-1 {
    position: absolute; top: 10%; left: 50%; transform: translateX(-50%);
    width: 900px; height: 500px;
    background: radial-gradient(ellipse, rgba(99, 102, 241, 0.12) 0%, transparent 60%);
    z-index: 0; pointer-events: none;
  }

  .ambient-glow-comm-2 {
    position: absolute; bottom: 10%; left: -10%;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.1) 0%, transparent 70%);
    z-index: 0; pointer-events: none;
  }

  /* Header */
  .community-header { text-align: center; margin-bottom: 4rem; }
  
  .logo-icon-wrapper-large {
    width: 70px; height: 70px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(168, 85, 247, 0.2));
    border: 1px solid rgba(168, 85, 247, 0.4); border-radius: 20px;
    display: flex; justify-content: center; align-items: center;
    box-shadow: 0 10px 30px rgba(168, 85, 247, 0.2);
  }

  .gradient-title {
    font-size: 3.5rem; font-weight: 800; letter-spacing: -1px;
    background: linear-gradient(135deg, #ffffff, #a1a1aa);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    margin-bottom: 15px;
  }

  /* Feature Grid (4 Steps) */
  .glass-feature-card {
    background: rgba(20, 20, 20, 0.6); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 24px; padding: 35px 25px;
    text-align: center; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .glass-feature-card:hover {
    transform: translateY(-10px); border-color: rgba(168, 85, 247, 0.3);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), inset 0 0 0 1px rgba(168, 85, 247, 0.1);
    background: rgba(25, 25, 25, 0.8);
  }

  .feature-icon-box {
    width: 60px; height: 60px; border-radius: 16px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(168, 85, 247, 0.2));
    border: 1px solid rgba(99, 102, 241, 0.4); color: #818cf8;
    display: flex; justify-content: center; align-items: center; font-size: 1.5rem;
    margin: 0 auto 20px; transition: transform 0.3s;
  }

  .glass-feature-card:hover .feature-icon-box { transform: scale(1.1); }
  .feature-title { color: #fff; font-weight: 700; font-size: 1.2rem; margin-bottom: 15px; }
  .feature-text { color: #a1a1aa; font-size: 0.95rem; line-height: 1.6; margin: 0; }

  .ainexus-divider { border-color: rgba(255,255,255,0.1); }

  /* Testimonials */
  .testimonial-glass-card {
    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
    border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 20px; padding: 30px;
    height: 100%; position: relative;
  }
  
  .quote-mark { position: absolute; top: 25px; right: 30px; font-size: 3rem; color: rgba(255,255,255,0.05); }
  .testimonial-text { color: #d4d4d8; font-size: 1.05rem; line-height: 1.6; font-style: italic; margin-bottom: 25px; position: relative; z-index: 2;}
  
  .testimonial-author { display: flex; align-items: center; gap: 15px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 20px;}
  .author-avatar {
    width: 45px; height: 45px; border-radius: 50%;
    background: #27272a; color: #e4e4e7;
    display: flex; justify-content: center; align-items: center; font-size: 1.2rem;
  }

  /* Discord CTA Banner */
  .discord-cta-banner {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    border-radius: 24px; padding: 50px 60px;
    display: flex; justify-content: space-between; align-items: center;
    position: relative; overflow: hidden; box-shadow: 0 20px 50px rgba(79, 70, 229, 0.3);
  }

  .cta-content { position: relative; z-index: 2; max-width: 600px; }
  .cta-content h3 { color: #fff; font-weight: 800; font-size: 2rem; margin-bottom: 15px; }
  .cta-content p { color: rgba(255,255,255,0.85); font-size: 1.1rem; line-height: 1.6; margin-bottom: 30px; }

  .btn-discord-glow {
    display: inline-block; background: #fff; color: #4f46e5;
    padding: 14px 30px; border-radius: 12px; font-weight: 700; font-size: 1.05rem;
    text-decoration: none; transition: all 0.3s ease; box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }
  .btn-discord-glow:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(0,0,0,0.3); color: #4f46e5; }

  .cta-visual { position: absolute; right: -5%; top: 50%; transform: translateY(-50%); opacity: 0.15; pointer-events: none;}
  .bg-icon { font-size: 25rem; color: #fff; }

  /* Animations */
  .fade-in-up { opacity: 0; animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  @keyframes fadeInUp { 0% { opacity: 0; transform: translateY(30px); } 100% { opacity: 1; transform: translateY(0); } }

  /* Mobile Adjustments */
  @media (max-width: 768px) {
    .gradient-title { font-size: 2.5rem; }
    .discord-cta-banner { padding: 40px 30px; text-align: center; }
    .cta-content { margin: 0 auto; }
  }
</style>