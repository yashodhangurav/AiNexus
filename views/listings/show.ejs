<% layout("/layouts/boilerplate.ejs") %>

<section class="ainexus-show-section">
  <div class="ambient-glow-show-1"></div>
  <div class="ambient-glow-show-2"></div>

  <div class="container relative-z pb-5">
    
    <div class="mb-4 fade-in-up">
      <a href="/home/listings" class="btn-glass-back">
        <i class="fa-solid fa-arrow-left me-2"></i> Back to Directory
      </a>
    </div>

    <div class="tool-hero-card fade-in-up">
      <div class="hero-card-left">
        <div class="tool-logo-large">
          <img 
            src="<%= listing.logo && listing.logo.url ? listing.logo.url : 'https://placehold.co/200x200/1e1b4b/a855f7?text=AI' %>" 
            alt="<%= listing.name %> Logo"
          >
        </div>
        <div class="tool-hero-info">
          <div class="d-flex align-items-center gap-3 mb-2">
            <h1 class="tool-name"><%= listing.name %></h1>
          </div>
          <div class="tool-badges mb-3">
            <span class="badge-category"><i class="fa-solid fa-layer-group"></i> <%= listing.category %></span>
            <span class="badge-pricing <%= listing.pricingModel === 'Free' ? 'free-tier' : 'paid-tier' %>">
              <i class="fa-solid fa-tag"></i> <%= listing.pricingModel || 'Pricing N/A' %>
            </span>
          </div>
          <% if(listing.tags && listing.tags.length > 0) { %>
            <div class="tool-tags">
              <% listing.tags.forEach(tag => { %>
                <span class="tag-hash">#<%= tag %></span>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
      
      <div class="hero-card-right">
        <a href="<%= listing.websiteUrl %>" target="_blank" rel="noopener noreferrer" class="btn-glow-primary btn-lg w-100 mb-3">
          Launch App <i class="fa-solid fa-arrow-up-right-from-square ms-2"></i>
        </a>
      </div>
    </div>

    <div class="row g-4 mt-2 fade-in-up" style="animation-delay: 0.1s;">
      
      <div class="col-lg-8">
        <div class="glass-panel">
          <h3 class="panel-title">About <%= listing.name %></h3>
          <p class="panel-text"><%= listing.description %></p>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="glass-panel sidebar-panel mb-4">
          <h4 class="sidebar-title">Submitted By</h4>
          <div class="submitter-profile">
            <div class="avatar-circle">
              <i class="fa-solid fa-user"></i>
            </div>
            <div class="submitter-info">
              <h5 class="mb-0"><%= listing.submittedBy ? listing.submittedBy.username : 'System Admin' %></h5>
              <small class="text-muted-custom">
                Joined <%= listing.submittedBy && listing.submittedBy.joinedAt ? new Date(listing.submittedBy.joinedAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) : 'Unknown' %>
              </small>
            </div>
          </div>
        </div>

        <% if(currUser && listing.submittedBy && currUser._id.equals(listing.submittedBy._id)) { %>
          <div class="glass-panel sidebar-panel border-accent">
            <h4 class="sidebar-title text-accent"><i class="fa-solid fa-shield-halved me-2"></i> Owner Controls</h4>
            <div class="d-flex flex-column gap-2 mt-3">
              <a href="/home/listings/<%= listing._id %>/edit" class="btn-glass-edit w-100 text-center">
                <i class="fa-solid fa-pen-to-square"></i> Edit Details
              </a>
              <form method="post" action="/home/listings/<%= listing._id %>?_method=DELETE" class="m-0">
                <button type="submit" class="btn-glass-delete w-100 text-center">
                  <i class="fa-solid fa-trash"></i> Delete Tool
                </button>
              </form>
            </div>
          </div>
        <% } %>
      </div>

    </div> <% if(listing.features && listing.features.length > 0) { %>
      <div class="row mt-4 fade-in-up" style="animation-delay: 0.15s;">
        <div class="col-12">
          <div class="glass-panel">
            <h3 class="panel-title mb-4"><i class="fa-solid fa-wand-magic-sparkles text-accent me-2"></i> Key Features</h3>
            <div class="feature-grid">
              <% listing.features.forEach(feature => { %>
                <div class="feature-card">
                  <div class="feature-icon"><i class="fa-solid fa-check"></i></div>
                  <span class="feature-text"><%= feature %></span>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    <% } %>

    <hr class="ainexus-divider my-5 fade-in-up" style="animation-delay: 0.2s;">

    <div class="row g-5 fade-in-up" style="animation-delay: 0.3s;">
      
      <div class="col-lg-5">
        <h3 class="panel-title mb-4"><i class="fa-solid fa-star text-warning me-2"></i> Community Reviews</h3>
        
        <% if(currUser) { %>
          <div class="glass-panel">
            <h5 class="text-white mb-3">Share your experience</h5>
            <form action="/home/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
              
              <div class="mb-3">
                <label class="form-label text-muted-custom mb-2">Overall Rating</label>
                <div class="star-rating d-block">
                  <input type="radio" id="star5" name="review[rating]" value="5" required/>
                  <label for="star5" class="fa-solid fa-star"></label>
                  <input type="radio" id="star4" name="review[rating]" value="4"/>
                  <label for="star4" class="fa-solid fa-star"></label>
                  <input type="radio" id="star3" name="review[rating]" value="3"/>
                  <label for="star3" class="fa-solid fa-star"></label>
                  <input type="radio" id="star2" name="review[rating]" value="2"/>
                  <label for="star2" class="fa-solid fa-star"></label>
                  <input type="radio" id="star1" name="review[rating]" value="1"/>
                  <label for="star1" class="fa-solid fa-star"></label>
                </div>
              </div>

              <div class="mb-4">
                <textarea id="comment" name="review[comment]" class="ainexus-textarea" rows="4" placeholder="What did you like or dislike about this tool?" required></textarea>
                <div class="invalid-feedback text-danger mt-1">Please write a review before submitting.</div>
              </div>

              <button type="submit" class="btn-glow-secondary w-100">Publish Review</button>
            </form>
          </div>
        <% } else { %>
          <div class="alert-glass-info">
            <i class="fa-solid fa-circle-info me-2"></i> You must be <a href="/login" class="text-accent fw-bold">logged in</a> to leave a review.
          </div>
        <% } %>
      </div>

      <div class="col-lg-7">
        <div class="reviews-list-container">
          <% if (listing.reviews && listing.reviews.length > 0) { %>
            <% listing.reviews.forEach(review => { %>
              <div class="review-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                  <div class="review-author-box">
                    <div class="review-avatar">
                      <i class="fa-solid fa-user"></i>
                    </div>
                    <div>
                      <div class="review-author-name"><%= review.author ? review.author.username : 'Anonymous User' %></div>
                      <small class="text-muted-custom"><%= new Date(review.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></small>
                    </div>
                  </div>
                  <div class="review-stars">
                    <% for(let i=1; i<=5; i++) { %>
                      <i class="fa-solid fa-star <%= i <= review.rating ? 'active' : 'inactive' %>"></i>
                    <% } %>
                  </div>
                </div>
                
                <p class="review-text"><%= review.comment %></p>
                
                <% if (currUser && review.author && currUser._id.equals(review.author._id)) { %>
                  <div class="text-end mt-3 border-top border-secondary pt-2">
                    <form method="post" action="/home/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=delete" class="m-0">
                      <button class="btn-text-danger"><i class="fa-solid fa-trash-can me-1"></i> Delete My Review</button>
                    </form>
                  </div>
                <% } %>
              </div>
            <% }) %>
          <% } else { %>
            <div class="empty-state-card text-center py-5 glass-panel">
              <i class="fa-regular fa-comment-dots fs-1 text-muted-custom mb-3"></i>
              <h5 class="text-white">No reviews yet</h5>
              <p class="text-muted-custom mb-0">Be the first to share your thoughts on <%= listing.name %>!</p>
            </div>
          <% } %>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .ainexus-show-section {
    position: relative;
    min-height: 100vh;
    background-color: #050505;
    padding: 120px 0 60px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #e4e4e7;
    overflow: hidden;
  }

  .relative-z { position: relative; z-index: 2; }
  .text-accent { color: #a855f7 !important; }
  .text-muted-custom { color: #a1a1aa; }

  /* Ambient Glows */
  .ambient-glow-show-1 {
    position: absolute; top: -10%; left: 50%; transform: translateX(-50%);
    width: 800px; height: 500px;
    background: radial-gradient(ellipse, rgba(99, 102, 241, 0.12) 0%, transparent 70%);
    z-index: 0; pointer-events: none;
  }

  .ambient-glow-show-2 {
    position: absolute; bottom: 0; right: -20%;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.1) 0%, transparent 70%);
    z-index: 0; pointer-events: none;
  }

  /* Buttons */
  .btn-glass-back {
    display: inline-flex; align-items: center;
    background: rgba(255, 255, 255, 0.05); color: #a1a1aa;
    padding: 8px 16px; border-radius: 50px; text-decoration: none; font-size: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.1); transition: all 0.3s ease;
  }
  .btn-glass-back:hover { background: rgba(255, 255, 255, 0.1); color: #fff; }

  .btn-glow-primary {
    display: inline-flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #6366f1, #a855f7); color: white; border: none;
    padding: 14px 24px; border-radius: 12px; font-size: 1.1rem; font-weight: 700; text-decoration: none;
    box-shadow: 0 8px 20px rgba(99, 102, 241, 0.3); transition: all 0.3s ease;
  }
  .btn-glow-primary:hover { transform: translateY(-2px); color: white; box-shadow: 0 12px 25px rgba(99, 102, 241, 0.5); }

  .btn-glow-secondary {
    background: rgba(168, 85, 247, 0.2); color: #c084fc; border: 1px solid rgba(168, 85, 247, 0.4);
    padding: 12px 20px; border-radius: 12px; font-weight: 600; transition: all 0.3s ease; border: none;
  }
  .btn-glow-secondary:hover { background: #a855f7; color: white; }

  /* Hero Card */
  .tool-hero-card {
    background: rgba(20, 20, 20, 0.7); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 24px; padding: 40px;
    display: flex; justify-content: space-between; align-items: center;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .hero-card-left { display: flex; gap: 30px; align-items: center; }
  .tool-logo-large {
    width: 120px; height: 120px; border-radius: 24px; overflow: hidden;
    background: #0f0f11; border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 10px 30px rgba(0,0,0,0.5); flex-shrink: 0;
  }
  .tool-logo-large img { width: 100%; height: 100%; object-fit: cover; }
  .tool-name { font-size: 2.5rem; font-weight: 800; color: #fff; margin: 0; letter-spacing: -1px; }
  
  .tool-badges { display: flex; gap: 10px; flex-wrap: wrap; }
  .badge-category { background: rgba(99, 102, 241, 0.15); color: #818cf8; padding: 6px 12px; border-radius: 50px; font-size: 0.85rem; font-weight: 600; border: 1px solid rgba(99, 102, 241, 0.3); }
  .badge-pricing { padding: 6px 12px; border-radius: 50px; font-size: 0.85rem; font-weight: 600; border: 1px solid; }
  .free-tier { background: rgba(16, 185, 129, 0.15); color: #34d399; border-color: rgba(16, 185, 129, 0.3); }
  .paid-tier { background: rgba(245, 158, 11, 0.15); color: #fbbf24; border-color: rgba(245, 158, 11, 0.3); }
  
  .tool-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag-hash { color: #a1a1aa; font-size: 0.85rem; background: rgba(255,255,255,0.05); padding: 4px 10px; border-radius: 8px; }

  .hero-card-right { min-width: 200px; }

  /* Glass Panels (FIXED HEIGHT ISSUE) */
  .glass-panel {
    background: rgba(20, 20, 20, 0.5); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px; padding: 30px; 
    /* Removed height: 100% so it fits content naturally without overflowing */
  }
  .panel-title { font-size: 1.4rem; font-weight: 700; color: #fff; margin-bottom: 20px; }
  .panel-text { color: #a1a1aa; line-height: 1.7; font-size: 1.05rem; white-space: pre-line; margin: 0; }

  /* NEW: Feature Grid Redesign */
  .feature-grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); 
    gap: 20px; 
  }
  .feature-card { 
    background: linear-gradient(135deg, rgba(255,255,255,0.02), rgba(255,255,255,0.05)); 
    border: 1px solid rgba(255,255,255,0.08); 
    border-radius: 16px; padding: 15px 20px; 
    display: flex; align-items: center; gap: 15px; 
    transition: transform 0.3s;
  }
  .feature-card:hover { transform: translateY(-4px); border-color: #a855f7; }
  .feature-icon { 
    width: 32px; height: 32px; border-radius: 50%; 
    background: rgba(168, 85, 247, 0.2); color: #c084fc; 
    display: flex; align-items: center; justify-content: center; font-size: 0.9rem;
  }
  .feature-text { color: #e4e4e7; font-size: 0.95rem; font-weight: 500; }

  /* Sidebar */
  .sidebar-panel { padding: 25px; }
  .sidebar-title { font-size: 1.1rem; font-weight: 600; color: #fff; margin-bottom: 15px; }
  .border-accent { border-color: rgba(168, 85, 247, 0.3); background: rgba(168, 85, 247, 0.03); }
  
  .submitter-profile { display: flex; align-items: center; gap: 15px; }
  .avatar-circle { width: 45px; height: 45px; border-radius: 50%; background: linear-gradient(135deg, #3f3f46, #27272a); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; color: #a1a1aa; }
  
  .btn-glass-edit { background: rgba(255,255,255,0.05); color: #fff; padding: 10px; border-radius: 10px; text-decoration: none; border: 1px solid rgba(255,255,255,0.1); transition: 0.2s; display: inline-block;}
  .btn-glass-edit:hover { background: rgba(255,255,255,0.1); color: #fff; }
  .btn-glass-delete { background: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 10px; border-radius: 10px; border: 1px solid rgba(239, 68, 68, 0.3); transition: 0.2s; }
  .btn-glass-delete:hover { background: #ef4444; color: #fff; }

  .ainexus-divider { border-color: rgba(255,255,255,0.1); }

  /* NEW: Reviews Section */
  .ainexus-textarea { width: 100%; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; color: #fff; padding: 15px; resize: vertical; transition: 0.3s; }
  .ainexus-textarea:focus { outline: none; border-color: #a855f7; box-shadow: 0 0 0 3px rgba(168, 85, 247, 0.2); }
  
  .reviews-list-container { display: flex; flex-direction: column; gap: 20px; }
  .review-card { background: rgba(20,20,20,0.6); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; padding: 25px; transition: transform 0.3s; }
  .review-card:hover { transform: translateY(-3px); border-color: rgba(255,255,255,0.15); }
  
  .review-author-box { display: flex; align-items: center; gap: 12px; }
  .review-avatar { width: 40px; height: 40px; border-radius: 50%; background: #27272a; display: flex; align-items: center; justify-content: center; color: #a1a1aa; }
  .review-author-name { font-weight: 700; color: #fff; font-size: 1.05rem; }
  
  .review-stars { font-size: 0.9rem; }
  .review-stars .active { color: #facc15; }
  .review-stars .inactive { color: #3f3f46; }
  .review-text { color: #d4d4d8; font-size: 1rem; line-height: 1.6; margin: 15px 0 0 0; }
  
  .btn-text-danger { background: none; border: none; color: #ef4444; transition: 0.2s; padding: 0; font-size: 0.9rem; font-weight: 600;}
  .btn-text-danger:hover { color: #b91c1c; }

  .alert-glass-info { background: rgba(56, 189, 248, 0.1); border: 1px solid rgba(56, 189, 248, 0.3); color: #e0f2fe; padding: 20px; border-radius: 16px; }

  /* Star Rating Input */
  .star-rating { direction: rtl; display: inline-flex; font-size: 1.8rem; }
  .star-rating input[type="radio"] { display: none; }
  .star-rating label { color: #3f3f46; cursor: pointer; transition: color 0.2s; padding: 0 4px; }
  .star-rating input[type="radio"]:checked ~ label { color: #facc15; }
  .star-rating label:hover, .star-rating label:hover ~ label { color: #fde047; }

  /* Animations */
  .fade-in-up { opacity: 0; animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  @keyframes fadeInUp { 0% { opacity: 0; transform: translateY(30px); } 100% { opacity: 1; transform: translateY(0); } }

  /* Mobile Adjustments */
  @media (max-width: 991px) {
    .tool-hero-card { flex-direction: column; align-items: flex-start; gap: 20px; padding: 30px; }
    .hero-card-left { flex-direction: column; align-items: flex-start; gap: 20px; }
    .hero-card-right { width: 100%; }
    .tool-logo-large { width: 80px; height: 80px; border-radius: 16px; }
    .tool-name { font-size: 2rem; }
  }
</style>

<script>
  // Bootstrap Form Validation
  (function () {
    'use strict'
    var forms = document.querySelectorAll('.needs-validation')
    Array.prototype.slice.call(forms).forEach(function (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault()
          event.stopPropagation()
        }
        form.classList.add('was-validated')
      }, false)
    })
  })()
</script>