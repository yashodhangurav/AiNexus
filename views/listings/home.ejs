<% layout("/layouts/boilerplate.ejs") %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AiNexus | The Ultimate AI Tool Directory</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* --- 1. CORE VARIABLES & SETUP --- */
        :root {
            --bg-dark: #050507;
            --surface: rgba(20, 20, 25, 0.6);
            --surface-hover: rgba(30, 30, 35, 0.8);
            --border-light: rgba(255, 255, 255, 0.08);
            --text-main: #ffffff;
            --text-muted: #94a3b8;
            --accent-primary: #6366f1;
            --accent-secondary: #a855f7;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- 2. LIGHTWEIGHT PURE CSS BACKGROUND --- */
        /* This replaces Three.js. It uses radial gradients that the browser's GPU renders instantly. */
        .bg-glow-container {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            z-index: -1; overflow: hidden; pointer-events: none;
        }
        .glow-orb {
            position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.15;
            animation: slowDrift 15s infinite alternate ease-in-out;
        }
        .glow-orb.orb-1 {
            top: -10%; left: -10%; width: 50vw; height: 50vw;
            background: radial-gradient(circle, var(--accent-primary), transparent 70%);
        }
        .glow-orb.orb-2 {
            bottom: -10%; right: -10%; width: 60vw; height: 60vw;
            background: radial-gradient(circle, var(--accent-secondary), transparent 70%);
            animation-delay: -5s;
        }

        @keyframes slowDrift {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(5%, 5%) scale(1.1); }
        }

        /* --- 3. HERO SECTION --- */
        .hero {
            min-height: 100vh; display: flex; flex-direction: column;
            justify-content: center; align-items: center; text-align: center;
            padding: 100px 20px 40px; position: relative;
        }

        .hero-badge {
            background: rgba(255, 255, 255, 0.05); border: 1px solid var(--border-light);
            padding: 8px 16px; border-radius: 50px; font-size: 0.85rem; color: var(--text-muted);
            margin-bottom: 24px; animation: fadeUp 0.8s ease backwards;
            backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
        }

        .hero h1 {
            font-size: clamp(2.5rem, 6vw, 4.5rem); /* Auto-scales on mobile */
            font-weight: 700; line-height: 1.1; letter-spacing: -1px;
            margin-bottom: 20px; max-width: 800px;
            animation: fadeUp 0.8s ease 0.1s backwards;
        }

        .text-accent {
            background: linear-gradient(135deg, #a855f7, #06b6d4);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }

        .hero p {
            font-size: clamp(1rem, 2vw, 1.25rem); color: var(--text-muted);
            max-width: 600px; margin-bottom: 40px;
            animation: fadeUp 0.8s ease 0.2s backwards;
        }

        /* Search Box */
        

        /* Categories */
        .categories {
            display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;
            margin-top: 30px; animation: fadeUp 0.8s ease 0.4s backwards;
        }
        .category-pill {
            padding: 8px 18px; background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-light); border-radius: 50px;
            color: var(--text-muted); font-size: 0.9rem; cursor: pointer;
            transition: all 0.3s ease;
        }
        .category-pill:hover, .category-pill.active {
            background: var(--text-main); color: #000; border-color: var(--text-main);
            transform: translateY(-2px);
        }

        /* --- 4. CSS FLOATING ICONS (No JS Required) --- */
        .floating-icon {
            position: absolute; background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-light); padding: 16px; border-radius: 16px;
            font-size: 1.5rem; color: var(--text-muted); z-index: -1;
            backdrop-filter: blur(5px); animation: floatUpAndDown 6s ease-in-out infinite;
            display: none; /* Hidden on mobile by default */
        }
        @media (min-width: 992px) {
            .floating-icon { display: block; }
            .icon-1 { top: 25%; left: 15%; animation-delay: 0s; }
            .icon-2 { top: 65%; left: 10%; animation-delay: -2s; }
            .icon-3 { top: 30%; right: 15%; animation-delay: -4s; }
            .icon-4 { top: 60%; right: 10%; animation-delay: -1s; }
        }

        @keyframes floatUpAndDown {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }

        /* --- 5. TRENDING SECTION & CARDS --- */
        .tools-section { padding: 80px; max-width: 1300px; margin: 0 auto; position: relative; }
        .section-header {
            margin-bottom: 40px; display: flex; justify-content: space-between; align-items: flex-end;
            animation: fadeUp 0.8s ease forwards;
        }
        .section-header h2 { font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 700; letter-spacing: -1px; }
        .view-all-link { color: var(--text-muted); text-decoration: none; transition: color 0.3s; }
        .view-all-link:hover { color: var(--text-main); }

        .tools-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;
        }

        /* Fast, Beautiful CSS-Only Hover Cards */
        .tool-card {
            background: var(--surface); border: 1px solid var(--border-light);
            border-radius: 20px; padding: 24px; display: flex; flex-direction: column;
            backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            animation: fadeUp 0.8s ease backwards;
        }
        
        .tool-card:hover {
            transform: translateY(-5px);
            background: var(--surface-hover);
            border-color: rgba(168, 85, 247, 0.3);
            box-shadow: 0 15px 35px rgba(0,0,0,0.3), 0 0 20px rgba(168, 85, 247, 0.1);
        }

        .card-header { display: flex; align-items: center; gap: 16px; margin-bottom: 16px; }
        .card-icon {
            width: 50px; height: 50px; border-radius: 14px; display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; color: white; background: #111; border: 1px solid var(--border-light);
        }

        .card-title h3 { font-size: 1.2rem; font-weight: 600; margin-bottom: 4px; }
        .card-title span {
            font-size: 0.75rem; color: var(--accent-primary); background: rgba(99, 102, 241, 0.1);
            padding: 3px 8px; border-radius: 6px; font-weight: 600;
        }

        .card-desc { color: var(--text-muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 24px; flex-grow: 1; }

        .card-footer { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border-light); padding-top: 16px; }
        .pricing { font-size: 0.85rem; color: var(--text-main); font-weight: 500; display: flex; align-items: center; gap: 6px; }
        .pricing i { color: #10b981; }

        .visit-link {
            color: var(--text-main); text-decoration: none; font-size: 0.9rem; font-weight: 600;
            display: flex; align-items: center; gap: 6px; transition: color 0.3s ease;
        }
        .tool-card:hover .visit-link { color: var(--accent-primary); }

        /* Animations */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* --- 6. MOBILE FIXES --- */
        @media (max-width: 768px) {
            .section-header { flex-direction: column; align-items: flex-start; gap: 10px; }
            .tools-section { padding: 60px 20px; }
        }
        /* --- 6. MOBILE FIXES & RESPONSIVENESS --- */
       /* --- 6. MOBILE FIXES & RESPONSIVENESS --- */
       @media (max-width: 768px) {
            /* 1. Fix the Hero gap */
            .hero { 
                min-height: auto; 
                /* Reduced bottom padding from 60px to 20px so it hugs the next section */
                padding: 130px 20px 20px; 
                justify-content: flex-start; 
            }

            .hero h1 { 
                font-size: 2.8rem; 
                margin-bottom: 16px;
            }

            .hero p {
                font-size: 1rem;
                margin-bottom: 30px;
            }

            /* 2. Scale down the search bar slightly */
            .search-container input {
                padding: 16px 60px 16px 45px;
                font-size: 1rem;
                border-radius: 20px;
            }

            .search-container > i.fa-magnifying-glass {
                left: 18px;
                font-size: 1.1rem;
            }

            .voice-search-btn {
                width: 36px;
                height: 36px;
                right: 10px;
                font-size: 1rem;
            }

            /* 3. Tighten the Tools Section spacing */
            .tools-section { 
                /* Reduced top padding from 80px to 30px to pull the header up */
                padding: 30px 20px 60px; 
            }

            .section-header { 
                flex-direction: column; 
                align-items: flex-start; 
                gap: 8px; 
                margin-bottom: 25px; /* Pulls the cards closer to the header text */
            }
            
            .section-header h2 {
                font-size: 1.8rem;
            }
        

            /* Scale down the search bar slightly so it isn't too bulky on phones */
            .search-container input {
                padding: 16px 60px 16px 45px;
                font-size: 1rem;
                border-radius: 20px;
            }

            .search-container > i.fa-magnifying-glass {
                left: 18px;
                font-size: 1.1rem;
            }

            .voice-search-btn {
                width: 36px;
                height: 36px;
                right: 10px;
                font-size: 1rem;
            }
        }
        

        /* ==========================================================================
   PREMIUM SEARCH BAR & VOICE ASSISTANT UI
   ========================================================================== */

/* 1. The Container */
.search-container {
    position: relative; 
    width: 100%; 
    max-width: 650px; 
    margin: 0 auto;
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s backwards;
}

/* 2. The Input Field */
.search-container input {
    width: 100%; 
    /* 56px left padding for the mag-glass, 75px right padding so text doesn't hit the mic button! */
    padding: 22px 75px 22px 56px; 
    background: rgba(15, 15, 20, 0.5); 
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px; 
    color: #ffffff; 
    font-size: 1.1rem;
    letter-spacing: 0.3px;
    backdrop-filter: blur(24px); 
    -webkit-backdrop-filter: blur(24px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.05);
}

.search-container input::placeholder {
    color: #71717a;
    font-weight: 400;
    transition: opacity 0.3s ease;
}

/* 3. Input Focus & Hover States */
.search-container input:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.15);
}

.search-container input:focus {
    outline: none; 
    background: rgba(10, 10, 15, 0.8);
    border-color: var(--accent-secondary); 
    box-shadow: 
        0 0 0 1px var(--accent-secondary), 
        0 20px 50px rgba(0, 0, 0, 0.6), 
        0 0 40px rgba(168, 85, 247, 0.15); 
    transform: translateY(-2px);
}

.search-container input:focus::placeholder {
    opacity: 0.5;
}

/* 4. The Left Magnifying Glass Icon */
.search-container > i.fa-magnifying-glass {
    position: absolute; 
    left: 24px; 
    top: 50%; 
    transform: translateY(-50%);
    color: #71717a; 
    font-size: 1.2rem;
    transition: color 0.4s ease, transform 0.4s ease;
    pointer-events: none; 
    z-index: 2;
}

/* Animate the mag-glass when the user clicks the input */
.search-container:focus-within > i.fa-magnifying-glass {
    color: var(--accent-secondary);
    transform: translateY(-50%) scale(1.1);
}

/* 5. The Right Voice Search Button */
.voice-search-btn {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #a1a1aa;
    width: 44px; /* Perfectly sized for touch/clicking */
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 10;
}

.voice-search-btn:hover {
    background: rgba(168, 85, 247, 0.15);
    color: #d8b4fe; /* Bright purple text */
    border-color: rgba(168, 85, 247, 0.4);
    transform: translateY(-50%) scale(1.08); /* Pops slightly on hover */
}

/* 6. The "Actively Listening" State */
.voice-search-btn.listening {
    background: rgba(239, 68, 68, 0.2); /* Red tint */
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.5);
    animation: pulseMic 1.5s infinite;
}

@keyframes pulseMic {
    0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
    70% { box-shadow: 0 0 0 12px rgba(239, 68, 68, 0); }
    100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
}
 </style>



</head>
<body>

    <div class="bg-glow-container">
        <div class="glow-orb orb-1"></div>
        <div class="glow-orb orb-2"></div>
    </div>

    <main class="main-content">
        <header class="hero">
            <div class="floating-icon icon-1"><i class="fa-solid fa-robot"></i></div>
            <div class="floating-icon icon-2"><i class="fa-solid fa-pen-nib"></i></div>
            <div class="floating-icon icon-3"><i class="fa-solid fa-code"></i></div>
            <div class="floating-icon icon-4"><i class="fa-solid fa-image"></i></div>

            <div class="hero-badge">✨ Discover over 1,000+ curated AI tools</div>
            <h1>Find the perfect AI tool for <span class="text-accent">every workflow</span></h1>
            <p>AiNexus is your centralized directory to discover, compare, and access the best artificial intelligence tools tailored for your specific needs.</p>
            
            <div class="search-container">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="homeSearchInput" placeholder="Search prompts, tools, or categories...">
                
                <button type="button" id="homeVoiceSearchBtn" class="voice-search-btn" title="Search by Voice">
                    <i class="fa-solid fa-microphone"></i>
                </button>
            </div>

            <div class="categories">
                <div class="category-pill active" data-category="all">All Tools</div>
                <div class="category-pill" data-category="Text Generation">Text & Writing</div>
                <div class="category-pill" data-category="Image Generation">Image Generation</div>
                <div class="category-pill" data-category="Code Assistant">Code Assistants</div>
            </div>
        </header>

        <section class="tools-section">
            <div class="section-header">
                <h2>Trending this week</h2>
                <a href="/home/listings" class="view-all-link">View all <i class="fa-solid fa-arrow-right ms-1"></i></a>
            </div>

            <div class="tools-grid">
                <div class="tool-card" style="animation-delay: 0.1s;">
                    <div class="card-header">
                        <div class="card-icon" style="background: linear-gradient(135deg, #10a37f, #0d8a6b);"><i class="fa-solid fa-bolt"></i></div>
                        <div class="card-title">
                            <h3>ChatGPT</h3>
                            <span>Text Generation</span>
                        </div>
                    </div>
                    <p class="card-desc">Advanced language model by OpenAI capable of coding, writing, and complex problem solving.</p>
                    <div class="card-footer">
                        <div class="pricing"><i class="fa-solid fa-circle-check"></i> Freemium</div>
                        <a href="/home/listings" class="visit-link">Explore <i class="fa-solid fa-arrow-right"></i></a>
                    </div>
                </div>

                <div class="tool-card" style="animation-delay: 0.2s;">
                    <div class="card-header">
                        <div class="card-icon" style="background: linear-gradient(135deg, #d946ef, #a855f7);"><i class="fa-solid fa-palette"></i></div>
                        <div class="card-title">
                            <h3>Midjourney</h3>
                            <span>Image Generation</span>
                        </div>
                    </div>
                    <p class="card-desc">Create highly detailed and artistic images from text prompts using Discord.</p>
                    <div class="card-footer">
                        <div class="pricing"><i class="fa-solid fa-circle-check" style="color:#a855f7"></i> Paid</div>
                        <a href="/home/listings" class="visit-link">Explore <i class="fa-solid fa-arrow-right"></i></a>
                    </div>
                </div>

                <div class="tool-card" style="animation-delay: 0.3s;">
                    <div class="card-header">
                        <div class="card-icon" style="background: linear-gradient(135deg, #3b82f6, #2563eb);"><i class="fa-solid fa-brain"></i></div>
                        <div class="card-title">
                            <h3>Claude 3</h3>
                            <span>Text Generation</span>
                        </div>
                    </div>
                    <p class="card-desc">Anthropic's latest AI model with massive context windows and exceptional reasoning.</p>
                    <div class="card-footer">
                        <div class="pricing"><i class="fa-solid fa-circle-check"></i> Freemium</div>
                        <a href="/home/listings" class="visit-link">Explore <i class="fa-solid fa-arrow-right"></i></a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Category Redirection
            document.querySelectorAll('.category-pill').forEach(pill => {
                pill.addEventListener('click', function() {
                    const category = this.getAttribute('data-category');
                    window.location.href = `/home/listings?category=${encodeURIComponent(category)}`;
                });
            });

            // Search Redirection
            const homeSearchInput = document.getElementById('homeSearchInput');
            if(homeSearchInput) {
                homeSearchInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter' && this.value.trim() !== '') {
                        window.location.href = `/home/listings?search=${encodeURIComponent(this.value)}`;
                    }
                });
            }
        });



// --- VOICE SEARCH LOGIC (Home Page) ---
const homeVoiceBtn = document.getElementById('homeVoiceSearchBtn');
            const micIcon = homeVoiceBtn ? homeVoiceBtn.querySelector('i') : null;

            if (homeVoiceBtn && homeSearchInput) {
                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                
                if (!SpeechRecognition) {
                    homeVoiceBtn.style.display = 'none'; // Hide if browser doesn't support it
                } else {
                    const recognition = new SpeechRecognition();
                    recognition.continuous = false;
                    recognition.interimResults = false;
                    recognition.lang = 'en-US';

                    recognition.onstart = function() {
                        homeVoiceBtn.classList.add('listening');
                        homeSearchInput.placeholder = "Listening... Speak now";
                        micIcon.classList.replace('fa-microphone', 'fa-ear-listen');
                    };

                    recognition.onresult = function(event) {
                        const transcript = event.results[0][0].transcript;
                        homeSearchInput.value = transcript;
                        
                        // INSTEAD of filtering, we immediately redirect to the Explore page!
                        window.location.href = `/home/listings?search=${encodeURIComponent(transcript)}`;
                    };

                    recognition.onend = function() {
                        homeVoiceBtn.classList.remove('listening');
                        homeSearchInput.placeholder = "Search prompts, tools, or categories...";
                        micIcon.classList.replace('fa-ear-listen', 'fa-microphone');
                    };

                    recognition.onerror = function(event) {
                        console.error("Voice search error:", event.error);
                        homeVoiceBtn.classList.remove('listening');
                        homeSearchInput.placeholder = "Microphone error or denied.";
                        setTimeout(() => {
                            homeSearchInput.placeholder = "Search prompts, tools, or categories...";
                        }, 3000);
                    };

                    homeVoiceBtn.addEventListener('click', () => {
                        if (homeVoiceBtn.classList.contains('listening')) {
                            recognition.stop();
                        } else {
                            recognition.start();
                        }
                    });
                }
            }
        
    </script>
</body>
</html>