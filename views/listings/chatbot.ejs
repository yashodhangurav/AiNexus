<% layout("/layouts/boilerplate.ejs") %>

<section class="nexus-chat-section">
    <div class="ambient-glow-chat-1"></div>
    <div class="ambient-glow-chat-2"></div>

    <div class="container d-flex justify-content-center align-items-center relative-z" style="height: calc(100vh - 100px);">
        
        <div class="chat-glass-window fade-in-up">
            
            <div class="chat-header">
                <div class="d-flex align-items-center gap-3">
                    <div class="header-icon-wrapper">
                        <i class="fa-solid fa-robot"></i>
                    </div>
                    <div>
                        <h2 class="chat-title">AiNexus Assistant</h2>
                        <div class="status-wrapper">
                            <span class="status-dot"></span>
                            <span class="status-text">Online & Ready</span>
                        </div>
                    </div>
                </div>
                <div class="header-actions">
                    <button class="icon-btn" title="Clear Chat" onclick="location.reload();">
                        <i class="fa-solid fa-rotate-right"></i>
                    </button>
                </div>
            </div>
            
            <div class="chat-messages-area" id="chat-messages">
                </div>
            
            <div class="chat-input-area">
                
                <div class="quick-prompts-wrapper">
                    <button class="prompt-chip" data-prompt="Find an image generator">🖼️ Image Generators</button>
                    <button class="prompt-chip" data-prompt="Best tools for coding?">💻 Coding Assistants</button>
                    <button class="prompt-chip" data-prompt="Free alternatives to ChatGPT">✨ Free Text AIs</button>
                    <button class="prompt-chip" data-prompt="How do I submit a tool?">🚀 Submit a Tool</button>
                </div>
                
                <div class="input-box-wrapper">
                    <textarea 
                        id="chat-input" 
                        placeholder="Ask me to find an AI tool, compare models, or navigate the directory..." 
                        rows="1"
                    ></textarea>
                    <button id="send-button" class="btn-send-glow">
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>
            </div>

        </div>
    </div>
</section>

<style>
    /* Section Setup */
    .nexus-chat-section {
        position: relative;
        background-color: #050505;
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: #e4e4e7;
        overflow: hidden;
        padding-top: 100px; /* Buffer for navbar */
    }

    .relative-z { position: relative; z-index: 2; }

    /* Ambient Glows */
    .ambient-glow-chat-1 {
        position: absolute; top: 10%; left: 10%; width: 500px; height: 500px;
        background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
        filter: blur(60px); z-index: 0; pointer-events: none;
    }
    .ambient-glow-chat-2 {
        position: absolute; bottom: 10%; right: 10%; width: 500px; height: 500px;
        background: radial-gradient(circle, rgba(168, 85, 247, 0.1) 0%, transparent 70%);
        filter: blur(60px); z-index: 0; pointer-events: none;
    }

    /* Main Chat Window */
    .chat-glass-window {
        width: 100%;
        max-width: 900px;
        height: 80vh;
        max-height: 800px;
        background: rgba(15, 15, 15, 0.6);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5), inset 0 0 0 1px rgba(168, 85, 247, 0.1);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    /* Header */
    .chat-header {
        padding: 20px 30px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.02);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header-icon-wrapper {
        width: 45px; height: 45px; border-radius: 14px;
        background: linear-gradient(135deg, #6366f1, #a855f7);
        display: flex; justify-content: center; align-items: center;
        font-size: 1.2rem; color: white;
        box-shadow: 0 5px 15px rgba(99, 102, 241, 0.4);
    }

    .chat-title { font-size: 1.2rem; font-weight: 700; color: #fff; margin: 0; letter-spacing: -0.5px; }
    
    .status-wrapper { display: flex; align-items: center; gap: 6px; margin-top: 2px; }
    .status-dot { width: 8px; height: 8px; background-color: #10b981; border-radius: 50%; box-shadow: 0 0 8px #10b981; animation: pulseOnline 2s infinite; }
    .status-text { font-size: 0.85rem; color: #a1a1aa; }

    .icon-btn { background: none; border: none; color: #71717a; font-size: 1.2rem; cursor: pointer; transition: color 0.3s; }
    .icon-btn:hover { color: #fff; }

    /* Messages Area */
    .chat-messages-area {
        flex: 1;
        padding: 30px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 20px;
        scroll-behavior: smooth;
    }

    /* Custom Scrollbar for Chat */
    .chat-messages-area::-webkit-scrollbar { width: 6px; }
    .chat-messages-area::-webkit-scrollbar-track { background: transparent; }
    .chat-messages-area::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
    .chat-messages-area::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }

    /* Message Bubbles */
    .chat-bubble-wrapper { display: flex; flex-direction: column; max-width: 80%; animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
    
    .chat-bubble-wrapper.user { align-self: flex-end; align-items: flex-end; }
    .chat-bubble-wrapper.bot { align-self: flex-start; align-items: flex-start; }

    .bubble-content { padding: 14px 20px; border-radius: 18px; font-size: 0.95rem; line-height: 1.5; position: relative; }
    
    .chat-bubble-wrapper.user .bubble-content {
        background: linear-gradient(135deg, #6366f1, #a855f7);
        color: white; border-bottom-right-radius: 4px;
        box-shadow: 0 10px 20px rgba(99, 102, 241, 0.2);
    }

    .chat-bubble-wrapper.bot .bubble-content {
        background: rgba(255, 255, 255, 0.05);
        color: #e4e4e7; border-bottom-left-radius: 4px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .bubble-time { font-size: 0.75rem; color: #71717a; margin-top: 6px; }

    /* Bot Avatar inline with message */
    .bot-avatar-inline {
        width: 28px; height: 28px; border-radius: 50%;
        background: rgba(168, 85, 247, 0.2); border: 1px solid rgba(168, 85, 247, 0.4);
        display: flex; justify-content: center; align-items: center;
        color: #c084fc; font-size: 0.7rem; margin-bottom: 8px;
    }

    /* Typing Indicator */
    .typing-indicator { display: flex; gap: 5px; padding: 5px 10px; }
    .typing-dot { width: 6px; height: 6px; background: #a1a1aa; border-radius: 50%; animation: typingBounce 1.4s infinite ease-in-out both; }
    .typing-dot:nth-child(1) { animation-delay: -0.32s; }
    .typing-dot:nth-child(2) { animation-delay: -0.16s; }

    /* Input Area */
    .chat-input-area {
        padding: 20px 30px 30px;
        background: rgba(5, 5, 5, 0.4);
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .quick-prompts-wrapper {
        display: flex; gap: 10px; overflow-x: auto; padding-bottom: 15px; margin-bottom: 5px;
    }
    .quick-prompts-wrapper::-webkit-scrollbar { height: 0px; } /* Hide scrollbar */

    .prompt-chip {
        background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1);
        color: #a1a1aa; padding: 8px 16px; border-radius: 50px; font-size: 0.85rem;
        cursor: pointer; white-space: nowrap; transition: all 0.3s ease;
    }
    .prompt-chip:hover { background: rgba(99, 102, 241, 0.15); border-color: #6366f1; color: #fff; }

    .input-box-wrapper { display: flex; gap: 15px; align-items: flex-end; }

    #chat-input {
        flex: 1; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px; padding: 15px 20px; color: #fff; font-size: 0.95rem; resize: none;
        max-height: 120px; min-height: 52px; transition: all 0.3s;
    }
    #chat-input:focus { outline: none; border-color: #a855f7; background: rgba(255, 255, 255, 0.06); box-shadow: 0 0 0 3px rgba(168, 85, 247, 0.15); }
    #chat-input::placeholder { color: #52525b; }

    .btn-send-glow {
        width: 52px; height: 52px; border-radius: 16px; border: none;
        background: linear-gradient(135deg, #6366f1, #a855f7); color: white;
        display: flex; justify-content: center; align-items: center; font-size: 1.2rem;
        cursor: pointer; transition: all 0.3s ease; box-shadow: 0 5px 15px rgba(99, 102, 241, 0.3);
        flex-shrink: 0;
    }
    .btn-send-glow:hover { transform: scale(1.05) translateY(-2px); box-shadow: 0 8px 25px rgba(99, 102, 241, 0.5); }
    .btn-send-glow:disabled { background: #3f3f46; color: #71717a; cursor: not-allowed; transform: none; box-shadow: none; }

    /* Animations */
    .fade-in-up { opacity: 0; animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    @keyframes fadeInUp { 0% { opacity: 0; transform: translateY(30px); } 100% { opacity: 1; transform: translateY(0); } }
    @keyframes popIn { 0% { opacity: 0; transform: scale(0.95) translateY(10px); } 100% { opacity: 1; transform: scale(1) translateY(0); } }
    @keyframes typingBounce { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
    @keyframes pulseOnline { 0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); } 70% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); } 100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); } }

    /* Mobile Tweaks */
    @media (max-width: 768px) {
        .nexus-chat-section { padding-top: 80px; }
        .container { height: calc(100vh - 80px) !important; padding: 0; }
        .chat-glass-window { height: 100%; max-height: none; border-radius: 0; border: none; }
        .chat-messages-area { padding: 20px; }
        .chat-input-area { padding: 15px 20px 20px; }
        .chat-bubble-wrapper { max-width: 90%; }
    }
</style>

<script>
    class AiNexusAssistant {
        constructor() {
            this.isProcessing = false;
            this.initElements();
            this.setupListeners();
            this.addWelcomeMessage();
        }

        initElements() {
            this.chatArea = document.getElementById('chat-messages');
            this.inputBox = document.getElementById('chat-input');
            this.sendBtn = document.getElementById('send-button');
        }

        setupListeners() {
            this.sendBtn.addEventListener('click', () => this.handleSend());
            
            this.inputBox.addEventListener('keypress', (e) => {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    this.handleSend();
                }
            });

            this.inputBox.addEventListener('input', () => {
                this.inputBox.style.height = 'auto';
                this.inputBox.style.height = Math.min(this.inputBox.scrollHeight, 120) + 'px';
            });

            document.querySelectorAll('.prompt-chip').forEach(chip => {
                chip.addEventListener('click', () => {
                    this.inputBox.value = chip.getAttribute('data-prompt');
                    this.handleSend();
                });
            });
        }

        addWelcomeMessage() {
            const msg = "Hi there! Welcome to AiNexus. I'm your AI directory assistant. I can help you discover new tools, compare models, or navigate the platform. What are you looking to build today?";
            this.renderMessage(msg, 'bot');
        }

        async handleSend() {
            const text = this.inputBox.value.trim();
            if (!text || this.isProcessing) return;

            // Render User Message
            this.renderMessage(text, 'user');
            this.inputBox.value = '';
            this.inputBox.style.height = 'auto';
            
            this.isProcessing = true;
            this.sendBtn.disabled = true;

            // Render Typing Indicator
            const typingId = this.renderTypingIndicator();

            try {
                // Simulate Network Delay
                await new Promise(r => setTimeout(r, 1200 + Math.random() * 800));
                const response = this.getMockResponse(text.toLowerCase());
                
                this.removeElement(typingId);
                this.renderMessage(response, 'bot');
                
            } catch (err) {
                this.removeElement(typingId);
                this.renderMessage("System anomaly detected. Please try asking again.", 'bot');
            } finally {
                this.isProcessing = false;
                this.sendBtn.disabled = false;
                this.inputBox.focus();
            }
        }

        getMockResponse(query) {
            if (query.includes('image') || query.includes('art') || query.includes('picture')) {
                return "For generating images, Midjourney is currently the community favorite for artistic quality. DALL-E 3 is excellent for prompt accuracy (and is built into ChatGPT Plus). If you want an open-source option, check out Stable Diffusion!";
            } else if (query.includes('code') || query.includes('program') || query.includes('dev')) {
                return "Developers love GitHub Copilot for IDE integration. However, Claude 3 Opus and Cursor (an AI-first code editor) are highly rated right now for tackling complex coding logic and refactoring.";
            } else if (query.includes('free')) {
                return "There are many great free tiers! ChatGPT (GPT-3.5/4o-mini) and Claude 3 Sonnet offer free daily limits. You can use the 'Pricing' filter on our Explore page to see all Free and Freemium tools.";
            } else if (query.includes('submit') || query.includes('add')) {
                return "To submit a tool, simply navigate to the 'Submit Tool' tab in the top navigation bar. You'll need to provide the tool's name, a brief description, its pricing model, and a logo.";
            } else if (query.includes('video')) {
                return "For video generation, Runway Gen-2 and Pika Labs are leading the industry. If you need video editing, tools like Descript or Opus Clip are highly recommended.";
            } else {
                return "I can certainly help with that. Try searching our directory using specific tags, or let me know if you are looking for tools related to writing, audio, coding, or productivity!";
            }
        }

        renderMessage(content, sender) {
            const id = 'msg-' + Date.now();
            const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            
            const html = `
                <div id="${id}" class="chat-bubble-wrapper ${sender}">
                    ${sender === 'bot' ? `<div class="bot-avatar-inline"><i class="fa-solid fa-sparkles"></i></div>` : ''}
                    <div class="bubble-content">${content}</div>
                    <span class="bubble-time">${time}</span>
                </div>
            `;
            
            this.chatArea.insertAdjacentHTML('beforeend', html);
            this.scrollToBottom();
        }

        renderTypingIndicator() {
            const id = 'typing-' + Date.now();
            const html = `
                <div id="${id}" class="chat-bubble-wrapper bot">
                    <div class="bot-avatar-inline"><i class="fa-solid fa-sparkles"></i></div>
                    <div class="bubble-content">
                        <div class="typing-indicator">
                            <div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>
                        </div>
                    </div>
                </div>
            `;
            this.chatArea.insertAdjacentHTML('beforeend', html);
            this.scrollToBottom();
            return id;
        }

        removeElement(id) {
            const el = document.getElementById(id);
            if (el) el.remove();
        }

        scrollToBottom() {
            this.chatArea.scrollTop = this.chatArea.scrollHeight;
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        new AiNexusAssistant();
    });
</script>