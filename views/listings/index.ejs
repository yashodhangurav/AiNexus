<% layout("/layouts/boilerplate.ejs") %>

<section class="directory-section">
  <div class="ambient-glow-dir-1"></div>
  <div class="ambient-glow-dir-2"></div>

  <div class="container directory-container relative-z">
    
    <div class="directory-header fade-in-up">
      <div class="badge-subtle mb-3 mx-auto">Directory Hub</div>
      <h1 class="gradient-title">Explore AI Tools</h1>
      <p class="text-muted-custom">Discover, compare, and integrate the perfect AI models for your workflow.</p>
    </div>

    <div class="search-filter-hub fade-in-up" style="animation-delay: 0.1s;">

      <div class="search-wrapper">
        <i class="fa-solid fa-magnifying-glass search-icon"></i>
        <input type="text" id="searchInput" placeholder="Search prompts, tools, or descriptions...">
        
        <div class="search-actions">
          <button type="button" id="voiceSearchBtn" class="voice-search-btn" title="Search by Voice">
            <i class="fa-solid fa-microphone"></i>
          </button>
      </div>
      </div>
      
      <div class="filter-controls">
        <div class="custom-select-wrapper">
          <i class="fa-solid fa-layer-group select-icon"></i>
          <select id="categoryFilter">
            <option value="all">All Categories</option>
            <option value="Text Generation">Text Generation</option>
            <option value="Image Generation">Image Generation</option>
            <option value="Video Editing">Video Editing</option>
            <option value="Code Assistant">Code Assistant</option>
            <option value="Productivity">Productivity</option>
            <option value="Chatbot">Chatbot</option>
            <option value="Voice AI">Voice AI</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="custom-select-wrapper">
          <i class="fa-solid fa-arrow-down-wide-short select-icon"></i>
          <select id="sortFilter">
            <option value="highest-rated">Highest Rated 🔥</option>
            <option value="newest">Newest First</option>
            <option value="oldest">Oldest First</option>
            <option value="a-z">Name (A-Z)</option>
            <option value="z-a">Name (Z-A)</option>
          </select>
        </div>
      </div>
    </div>

    <div class="row g-4" id="toolsGrid">
      <% for(let listing of allListings) { %>
        
        <% 
          let totalRating = 0;
          let avgRating = 0;
          let reviewCount = listing.reviews ? listing.reviews.length : 0;
          if(reviewCount > 0) {
            listing.reviews.forEach(review => {
              totalRating += review.rating;
            });
            avgRating = (totalRating / reviewCount).toFixed(1);
          }
        %>

        <div class="col-xl-4 col-lg-4 col-md-6 tool-card-col" 
             data-name="<%= listing.name.toLowerCase() %>" 
             data-desc="<%= listing.description.toLowerCase() %>"
             data-category="<%= listing.category %>"
             data-rating="<%= avgRating %>"
             data-date="<%= new Date(listing._id.getTimestamp()).getTime() %>">
          
          <div class="spotlight-card h-100 fade-in-up-stagger">
            <div class="card-inner">
              
              <div class="card-top-row">
                <div class="tool-icon-wrapper">
                  <img 
                    src="<%= listing.logo && listing.logo.url ? listing.logo.url : 'https://placehold.co/200x200/1e1b4b/a855f7?text=AI' %>" 
                    alt="<%= listing.name %> logo" loading="lazy">
                </div>
                <div class="card-badges text-end">
                  <% if(avgRating >= 4.5 && reviewCount > 0) { %>
                    <span class="top-rated-badge mb-2 d-inline-block"><i class="fa-solid fa-trophy me-1"></i> Top Rated</span>
                  <% } %>
                  <div>
                    <span class="pricing-pill <%= listing.pricingModel === 'Free' ? 'free-tier' : 'paid-tier' %>">
                      <i class="fa-solid fa-tag me-1"></i> <%= listing.pricingModel || 'Unknown' %>
                    </span>
                  </div>
                </div>
              </div>

              <div class="card-content flex-grow-1">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <h3 class="tool-title mb-0"><%= listing.name %></h3>
                  <span class="category-text"><%= listing.category %></span>
                </div>
                
                <div class="review-stars mb-3">
                  <% if(reviewCount > 0) { %>
                    <span class="star-rating">
                      <i class="fa-solid fa-star"></i> <%= avgRating %>
                    </span>
                    <span class="review-count">(<%= reviewCount %> reviews)</span>
                  <% } else { %>
                    <span class="review-count">No reviews yet</span>
                  <% } %>
                </div>

                <p class="tool-desc">
                  <%= listing.description.length > 100 ? listing.description.substring(0, 100) + '...' : listing.description %>
                </p>

                <% if(listing.features && listing.features.length > 0) { %>
                  <div class="feature-tags mb-3">
                    <% for(let i = 0; i < Math.min(3, listing.features.length); i++) { %>
                      <span class="feature-tag"><i class="fa-solid fa-check text-accent-cyan"></i> <%= listing.features[i] %></span>
                    <% } %>
                    <% if(listing.features.length > 3) { %>
                      <span class="feature-tag">+<%= listing.features.length - 3 %> more</span>
                    <% } %>
                  </div>
                <% } %>
              </div>

              <div class="card-actions mt-3 pt-3 border-top-subtle">
                <a href="/home/listings/<%= listing._id %>" class="btn-glass-sm text-center flex-grow-1">
                  Details
                </a>
                <a href="<%= listing.websiteUrl %>" target="_blank" rel="noopener noreferrer" class="btn-glow-sm text-center flex-grow-1">
                  Visit <i class="fa-solid fa-arrow-up-right-from-square ms-1"></i>
                </a>
              </div>

            </div>
          </div>
        </div>
      <% } %>
    </div>
    
    <div id="noResults" class="empty-state py-5 d-none">
      <div class="empty-icon"><i class="fa-solid fa-ghost"></i></div>
      <h4>No AI tools found</h4>
      <p>Try adjusting your search or category filter.</p>
      <button class="btn-glass-sm mt-3" onclick="resetFilters()">Clear Filters</button>
    </div>

  </div>
</section>

