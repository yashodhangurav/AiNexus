<script>


  // --------------------------------------------------------------VOICE SEARCH BUTTON-----------------------------
  document.addEventListener('DOMContentLoaded', () => {
    const voiceSearchBtn = document.getElementById('voiceSearchBtn');
    const searchInput = document.getElementById('searchInput');
    const micIcon = voiceSearchBtn.querySelector('i');

    // 1. Check if the browser supports the Web Speech API
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    
    if (!SpeechRecognition) {
      // If the browser doesn't support it (like some older browsers), hide the button
      voiceSearchBtn.style.display = 'none';
      return;
    }

    // 2. Initialize the Voice Assistant
    const recognition = new SpeechRecognition();
    recognition.continuous = false; // Stop listening after they stop talking
    recognition.interimResults = false; // Only give us the final confirmed sentence
    recognition.lang = 'en-US'; // Set language

    // 3. Handle when the microphone starts listening
    recognition.onstart = function() {
      voiceSearchBtn.classList.add('listening');
      searchInput.placeholder = "Listening... Speak now";
      micIcon.classList.remove('fa-microphone');
      micIcon.classList.add('fa-ear-listen');
    };

    // 4. Handle when the user finishes speaking and we get a result
    recognition.onresult = function(event) {
      const transcript = event.results[0][0].transcript;
      
      // Put the spoken words into the search bar
      searchInput.value = transcript;
      
      // Trigger the search automatically!
      // This forces the "input" event so your existing filter script knows to run
      searchInput.dispatchEvent(new Event('input', { bubbles: true })); 
    };

    // 5. Handle cleanup when the microphone stops
    recognition.onend = function() {
      voiceSearchBtn.classList.remove('listening');
      searchInput.placeholder = "Search prompts, tools, or descriptions...";
      micIcon.classList.remove('fa-ear-listen');
      micIcon.classList.add('fa-microphone');
    };

    // 6. Handle Errors (e.g., user denied microphone permission)
    recognition.onerror = function(event) {
      console.error("Voice search error:", event.error);
      voiceSearchBtn.classList.remove('listening');
      searchInput.placeholder = "Microphone error or denied.";
      setTimeout(() => {
        searchInput.placeholder = "Search prompts, tools, or descriptions...";
      }, 3000);
    };

    // 7. Start listening when the button is clicked
    voiceSearchBtn.addEventListener('click', () => {
      if (voiceSearchBtn.classList.contains('listening')) {
        recognition.stop(); // If already listening, stop it
      } else {
        recognition.start(); // Start listening
      }
    });
  });

  // --- ON LOAD: Check if Home Page sent us here with AI mode! ---
  // const urlParams = new URLSearchParams(window.location.search);
  
</script>
























<script>
  document.addEventListener('DOMContentLoaded', () => {
      
      // --- 1. Spotlight Hover Effect ---
      const cards = document.querySelectorAll('.spotlight-card');
      cards.forEach(card => {
          card.addEventListener('mousemove', e => {
              const rect = card.getBoundingClientRect();
              card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
              card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
          });
      });
  
      // --- 2. DOM Elements ---
      const searchInput = document.getElementById('searchInput');
      const categoryFilter = document.getElementById('categoryFilter');
      const sortFilter = document.getElementById('sortFilter');
      const toolsGrid = document.getElementById('toolsGrid');
      const noResultsMsg = document.getElementById('noResults');
      const toolCards = Array.from(document.querySelectorAll('.tool-card-col'));
      
      let debounceTimer;
  
      // --- 3. The Master Search Function ---
      async function runSearch() {
          const query = searchInput.value.trim().toLowerCase();
          const selectedCategory = categoryFilter.value;
          const sortBy = sortFilter.value;
  
          // Step 1: Hide all cards initially to prevent ghosting
          toolCards.forEach(card => card.classList.add('d-none'));
          noResultsMsg.classList.add('d-none');
  
          let visibleCount = 0;
  
          // ==========================================
          // SCENARIO A: AI CLOUD SEARCH (User is typing)
          // ==========================================
          if (query.length > 0) {
              searchInput.placeholder = "✨ AI is thinking...";
              
              try {
                  // Ping the MongoDB Atlas Backend
                  const response = await fetch(`/home/listings/smart-search?query=${encodeURIComponent(query)}`);
                  if (!response.ok) throw new Error("Backend connection failed");
                  
                  const aiResults = await response.json();
                  
                  // Match AI results to the HTML cards
                  aiResults.forEach((item, index) => {
                      const matchedCard = toolCards.find(card => card.getAttribute('data-name') === item.name.toLowerCase());
                      
                      // Respect the Category dropdown even during AI search!
                      const matchesCategory = selectedCategory === 'all' || matchedCard.getAttribute('data-category') === selectedCategory;
                      
                      if (matchedCard && item.score > 0.05 && matchesCategory) {
                          matchedCard.classList.remove('d-none');
                          matchedCard.style.order = index; // AI decides the exact order
                          visibleCount++;
                      }
                  });
              } catch (error) {
                  console.error("AI Search Failed:", error);
                  noResultsMsg.innerHTML = `<div class="empty-icon"><i class="fa-solid fa-triangle-exclamation text-danger"></i></div><h4>Connection Error</h4><p>Failed to reach MongoDB Vector Search.</p>`;
              }
              searchInput.placeholder = "Describe what you want to achieve with AI...";
          } 
          
          // ==========================================
          // SCENARIO B: STANDARD FILTERING (Search bar is empty)
          // ==========================================
          else {
              let visibleCards = [];
              toolCards.forEach(card => {
                  const category = card.getAttribute('data-category');
                  if (selectedCategory === 'all' || category === selectedCategory) {
                      card.classList.remove('d-none');
                      visibleCards.push(card);
                      visibleCount++;
                  }
              });
  
              // Apply standard sorting (Highest Rated, Newest, etc.)
              visibleCards.sort((a, b) => {
                  const nameA = a.getAttribute('data-name');
                  const nameB = b.getAttribute('data-name');
                  const dateA = parseInt(a.getAttribute('data-date'));
                  const dateB = parseInt(b.getAttribute('data-date'));
                  const ratingA = parseFloat(a.getAttribute('data-rating')) || 0;
                  const ratingB = parseFloat(b.getAttribute('data-rating')) || 0;
  
                  if (sortBy === 'highest-rated') return ratingB - ratingA;
                  if (sortBy === 'a-z') return nameA.localeCompare(nameB);
                  if (sortBy === 'z-a') return nameB.localeCompare(nameA);
                  if (sortBy === 'newest') return dateB - dateA; 
                  if (sortBy === 'oldest') return dateA - dateB;
              });
  
              visibleCards.forEach((card, index) => {
                  card.style.order = index;
              });
          }
  
          // --- Handle "No Results" Message ---
          if (visibleCount === 0 && !noResultsMsg.classList.contains('text-danger')) {
              noResultsMsg.innerHTML = `<div class="empty-icon"><i class="fa-solid fa-ghost"></i></div><h4>No AI tools found</h4><p>Try adjusting your search or category filter.</p><button class="btn-glass-sm mt-3" onclick="resetFilters()">Clear Filters</button>`;
              noResultsMsg.classList.remove('d-none');
          }
      }
  
      // --- 4. Event Listeners ---
      searchInput.addEventListener('input', () => {
          clearTimeout(debounceTimer);
          debounceTimer = setTimeout(runSearch, 300); // 300ms Debounce to save server costs!
      });
      categoryFilter.addEventListener('change', runSearch);
      sortFilter.addEventListener('change', runSearch);
  
      // --- 5. Voice Search Integration ---
      const voiceSearchBtn = document.getElementById('voiceSearchBtn');
      const micIcon = voiceSearchBtn ? voiceSearchBtn.querySelector('i') : null;
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      
      if (SpeechRecognition && voiceSearchBtn) {
          const recognition = new SpeechRecognition();
          recognition.continuous = false;
          recognition.interimResults = false;
          recognition.lang = 'en-US';
  
          recognition.onstart = () => {
              voiceSearchBtn.classList.add('listening');
              searchInput.placeholder = "Listening... Speak now";
              micIcon.classList.replace('fa-microphone', 'fa-ear-listen');
          };
          recognition.onresult = (event) => {
              searchInput.value = event.results[0][0].transcript;
              runSearch(); // Instantly trigger the master search
          };
          recognition.onend = () => {
              voiceSearchBtn.classList.remove('listening');
              searchInput.placeholder = "Describe what you want to achieve with AI...";
              micIcon.classList.replace('fa-ear-listen', 'fa-microphone');
          };
          recognition.onerror = () => {
              voiceSearchBtn.classList.remove('listening');
              searchInput.placeholder = "Microphone error or denied.";
              setTimeout(() => searchInput.placeholder = "Describe what you want to achieve with AI...", 3000);
          };
          voiceSearchBtn.addEventListener('click', () => {
              voiceSearchBtn.classList.contains('listening') ? recognition.stop() : recognition.start();
          });
      } else if (voiceSearchBtn) {
          voiceSearchBtn.style.display = 'none'; // Hide mic if browser doesn't support it
      }
  
      // --- 6. Auto-Boot from Home Page URL ---
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('category')) categoryFilter.value = urlParams.get('category');
      if (urlParams.get('search')) searchInput.value = urlParams.get('search');
      
      // Run exactly once on load to handle filters or Home Page redirects
      runSearch(); 
  });
  
  // --- Helper: Clear Filters Button ---
  window.resetFilters = function() {
      document.getElementById('searchInput').value = '';
      document.getElementById('categoryFilter').value = 'all';
      document.getElementById('sortFilter').value = 'highest-rated';
      document.getElementById('searchInput').dispatchEvent(new Event('input'));
  };
  </script>