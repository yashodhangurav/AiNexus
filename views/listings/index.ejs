<% layout("/layouts/boilerplate.ejs") %>

<section class="directory-section">
  <div class="ambient-glow-dir-1"></div>
  <div class="ambient-glow-dir-2"></div>

  <div class="container directory-container relative-z">
    
    <div class="directory-header fade-in-up">
      <h1 class="gradient-title">Explore AI Tools</h1>
      <p class="text-muted-custom">Discover, compare, and integrate the perfect AI models for your workflow.</p>
    </div>

    <div class="row g-4">
      <% for(let listing of allListings) { %>
        <div class="col-xl-4 col-lg-4 col-md-6">
          <div class="ainexus-tool-card h-100 fade-in-up-stagger">
            
            <div class="card-top-row">
              <div class="tool-icon-wrapper">
                <img 
                  src="<%= listing.logo || 'https://placehold.co/200x200/1e1b4b/a855f7?text=AI' %>" 
                  alt="<%= listing.name %> logo"
                  loading="lazy"
                >
              </div>
              <span class="category-pill">
                <i class="fa-solid fa-layer-group me-1"></i> <%= listing.category %>
              </span>
            </div>

            <div class="card-content">
              <h3 class="tool-title"><%= listing.name %></h3>
              <p class="tool-desc">
                <%= listing.description.length > 110 ? listing.description.substring(0, 110) + '...' : listing.description %>
              </p>
            </div>

            <div class="card-actions mt-auto">
              <a href="/home/listings/<%= listing._id %>" class="btn-glass-sm w-100 text-center">
                View Details
              </a>
              <a href="<%= listing.websiteUrl %>" target="_blank" rel="noopener noreferrer" class="btn-glow-sm w-100 text-center">
                Visit <i class="fa-solid fa-arrow-up-right-from-square ms-1"></i>
              </a>
            </div>

          </div>
        </div>
      <% } %>
    </div>

  </div>
</section>

<style>
  /* Base Section Setup */
  .directory-section {
    position: relative;
    min-height: 100vh;
    background-color: #050505;
    padding: 120px 0 80px; /* Accounts for floating navbar */
    font-family: 'Plus Jakarta Sans', sans-serif;
    overflow: hidden;
  }

  .relative-z {
    position: relative;
    z-index: 2;
  }

  /* Ambient Backgrounds */
  .ambient-glow-dir-1 {
    position: absolute;
    top: 10%;
    left: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12) 0%, transparent 70%);
    filter: blur(60px);
    z-index: 0;
    pointer-events: none;
  }

  .ambient-glow-dir-2 {
    position: absolute;
    bottom: 10%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.1) 0%, transparent 70%);
    filter: blur(60px);
    z-index: 0;
    pointer-events: none;
  }

  /* Header */
  .directory-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .gradient-title {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -1px;
    background: linear-gradient(135deg, #ffffff, #a1a1aa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 10px;
  }

  .text-muted-custom {
    color: #a1a1aa;
    font-size: 1.1rem;
  }

  /* --- Premium Glassmorphic Card --- */
  .ainexus-tool-card {
    display: flex;
    flex-direction: column;
    background: rgba(20, 20, 20, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 24px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .ainexus-tool-card:hover {
    transform: translateY(-8px);
    border-color: rgba(168, 85, 247, 0.4);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6), inset 0 0 0 1px rgba(168, 85, 247, 0.1);
    background: rgba(25, 25, 25, 0.8);
  }

  /* Card Top Row (Logo & Badge) */
  .card-top-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
  }

  .tool-icon-wrapper {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    overflow: hidden;
    background: #0f0f11;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 5px 15px rgba(0,0,0,0.5);
  }

  .tool-icon-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .category-pill {
    background: rgba(99, 102, 241, 0.15);
    color: #818cf8;
    border: 1px solid rgba(99, 102, 241, 0.3);
    padding: 6px 12px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
  }

  /* Card Body */
  .tool-title {
    color: #ffffff;
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 10px;
    letter-spacing: -0.3px;
  }

  .tool-desc {
    color: #a1a1aa;
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  /* Card Actions */
  .card-actions {
    display: flex;
    gap: 12px;
  }

  .btn-glass-sm {
    background: rgba(255, 255, 255, 0.05);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 10px 16px;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-glass-sm:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: #ffffff;
  }

  .btn-glow-sm {
    background: linear-gradient(135deg, #6366f1, #a855f7);
    color: #ffffff;
    border: none;
    padding: 10px 16px;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
  }

  .btn-glow-sm:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(99, 102, 241, 0.5);
    color: #ffffff;
  }

  /* Entrance Animations */
  .fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .fade-in-up-stagger {
    opacity: 0;
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.2s; /* Add some staggered JS logic here if desired later */
  }

  @keyframes fadeInUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* Mobile Tweaks */
  @media (max-width: 768px) {
    .gradient-title {
      font-size: 2.2rem;
    }
    .card-actions {
      flex-direction: column;
    }
  }
</style>